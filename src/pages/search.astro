---
import { env } from 'cloudflare:workers';
import BaseLayout from '../layouts/BaseLayout.astro';
import ImageCard from '../components/ImageCard.astro';

if (!env || !env.DB) {
  return new Response('D1 DB binding not configured.', { status: 500 });
}

// 1. Get search parameters
const q = Astro.url.searchParams.get('q') || '';
const filterTag = Astro.url.searchParams.get('tag') || '';
const filterAuthor = Astro.url.searchParams.get('author') || '';

// 2. Fetch all tags for listing
const tagsQuery = await env.DB.prepare('SELECT name FROM tags ORDER BY name ASC').all();
const allTags = tagsQuery.results.map((t: any) => t.name);

// 3. Fetch all distinct authors for listing
const authorsQuery = await env.DB.prepare('SELECT DISTINCT author, author_url FROM images ORDER BY author ASC').all();
const allAuthors = authorsQuery.results as { author: string; author_url: string }[];

// 4. Perform search query if any filter is active
let images = [];
let searchHeading = '';

try {
  if (q) {
    searchHeading = `🔍 搜尋關鍵字："${q}"`;
    const sql = `
      SELECT i.*, group_concat(t2.name) as tags_list 
      FROM images i
      LEFT JOIN image_tags it ON i.id = it.image_id
      LEFT JOIN tags t ON it.tag_id = t.id
      LEFT JOIN image_tags it2 ON i.id = it2.image_id
      LEFT JOIN tags t2 ON it2.tag_id = t2.id
      WHERE i.title LIKE ? 
         OR i.description LIKE ? 
         OR i.author LIKE ? 
         OR t.name LIKE ?
      GROUP BY i.id
      ORDER BY i.created_at DESC
    `;
    const searchVal = `%${q}%`;
    const { results } = await env.DB.prepare(sql)
      .bind(searchVal, searchVal, searchVal, searchVal)
      .all();
    images = results || [];
  } else if (filterTag) {
    searchHeading = `🏷️ 標籤篩選：#${filterTag}`;
    const sql = `
      SELECT i.*, group_concat(t2.name) as tags_list 
      FROM images i
      JOIN image_tags it ON i.id = it.image_id
      JOIN tags t ON it.tag_id = t.id
      LEFT JOIN image_tags it2 ON i.id = it2.image_id
      LEFT JOIN tags t2 ON it2.tag_id = t2.id
      WHERE t.name = ?
      GROUP BY i.id
      ORDER BY i.created_at DESC
    `;
    const { results } = await env.DB.prepare(sql).bind(filterTag).all();
    images = results || [];
  } else if (filterAuthor) {
    searchHeading = `👤 博主篩選：@${filterAuthor}`;
    const sql = `
      SELECT i.*, group_concat(t.name) as tags_list
      FROM images i
      LEFT JOIN image_tags it ON i.id = it.image_id
      LEFT JOIN tags t ON it.tag_id = t.id
      WHERE i.author = ?
      GROUP BY i.id
      ORDER BY i.created_at DESC
    `;
    const { results } = await env.DB.prepare(sql).bind(filterAuthor).all();
    images = results || [];
  }
} catch (err) {
  console.error('Search query failed:', err);
}

const formattedImages = images.map((img: any) => ({
  ...img,
  tags: img.tags_list ? img.tags_list.split(',') : []
}));
---

<BaseLayout title="搜尋與篩選 - Twitter 照片牆">
  <div class="search-page-container">
    <div class="search-bar-section">
      <form action="/search" method="GET" class="search-form">
        <div class="search-input-wrapper">
          <span class="search-icon-left">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
          </span>
          <input 
            type="search" 
            name="q" 
            value={q} 
            placeholder="搜尋相片標題、博主、標籤或感想..." 
            class="search-input"
            required
          />
        </div>
        <button type="submit" class="btn btn-primary search-submit-btn">搜尋</button>
      </form>
    </div>

    <!-- Tags and Authors Directory -->
    <div class="directory-section">
      <div class="directory-column">
        <h3>👤 依博主瀏覽</h3>
        <div class="author-links">
          {allAuthors.length > 0 ? (
            allAuthors.map((item) => (
              <a 
                href={`/search?author=${encodeURIComponent(item.author)}`} 
                class={`author-badge ${filterAuthor === item.author ? 'active' : ''}`}
              >
                @{item.author}
              </a>
            ))
          ) : (
            <p class="empty-text">尚無博主資料</p>
          )}
        </div>
      </div>

      <div class="directory-column">
        <h3>🏷️ 依標籤瀏覽</h3>
        <div class="tag-badges">
          {allTags.length > 0 ? (
            allTags.map((tag) => (
              <a 
                href={`/search?tag=${encodeURIComponent(tag)}`} 
                class={`tag-badge ${filterTag === tag ? 'active' : ''}`}
              >
                #{tag}
              </a>
            ))
          ) : (
            <p class="empty-text">尚無標籤資料</p>
          )}
        </div>
      </div>
    </div>

    <!-- Search Results Section -->
    {(q || filterTag || filterAuthor) && (
      <div class="results-section">
        <h2 class="results-heading">{searchHeading} ({formattedImages.length})</h2>
        {formattedImages.length > 0 ? (
          <div class="image-grid">
            {formattedImages.map((image) => (
              <ImageCard image={image} />
            ))}
          </div>
        ) : (
          <div class="no-results">
            <p class="no-results-emoji">🔍</p>
            <h3>找不到相關照片</h3>
            <p>請嘗試使用其他關鍵字或點擊上方標籤進行篩選。</p>
          </div>
        )}
      </div>
    )}
  </div>
</BaseLayout>

<script>
  // Setup click listeners for like buttons on search page
  function setupLikes() {
    document.querySelectorAll('.image-card').forEach((card) => {
      const imgId = card.getAttribute('data-id');
      const likeBtn = card.querySelector('.like-button');
      const likeCountSpan = card.querySelector('.like-count');

      if (!likeBtn || !likeCountSpan || !imgId) return;

      // Restore likes
      const likedImages = JSON.parse(localStorage.getItem('liked-images') || '[]');
      if (likedImages.includes(parseInt(imgId, 10))) {
        likeBtn.classList.add('liked');
      }

      likeBtn.addEventListener('click', async () => {
        const likedImages = JSON.parse(localStorage.getItem('liked-images') || '[]');
        const idNum = parseInt(imgId, 10);
        const isLiked = likedImages.includes(idNum);
        const action = isLiked ? 'unlike' : 'like';

        try {
          if (action === 'like') {
            likeBtn.classList.add('liked');
          } else {
            likeBtn.classList.remove('liked');
          }

          const response = await fetch(`/api/likes/${imgId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action })
          });
          const data = await response.json();
          if (data.success) {
            likeCountSpan.textContent = data.likes;
            if (action === 'like') {
              likedImages.push(idNum);
            } else {
              const idx = likedImages.indexOf(idNum);
              if (idx > -1) likedImages.splice(idx, 1);
            }
            localStorage.setItem('liked-images', JSON.stringify(likedImages));
          } else {
            // Revert state
            if (action === 'like') {
              likeBtn.classList.remove('liked');
            } else {
              likeBtn.classList.add('liked');
            }
          }
        } catch (err) {
          console.error(`Failed to ${action} image:`, err);
          // Revert state
          if (action === 'like') {
            likeBtn.classList.remove('liked');
          } else {
            likeBtn.classList.add('liked');
          }
        }
      });
    });
  }

  setupLikes();
  document.addEventListener('astro:after-swap', setupLikes);
</script>

<style>
  .search-page-container {
    padding: 2.5rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .search-bar-section {
    max-width: 600px;
    margin: 0 auto;
    width: 100%;
  }

  .search-form {
    display: flex;
    gap: 0.6rem;
    width: 100%;
    align-items: center;
  }

  .search-input-wrapper {
    position: relative;
    flex: 1;
    display: flex;
    align-items: center;
  }

  .search-icon-left {
    position: absolute;
    left: 1.1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-secondary);
    opacity: 0.7;
    pointer-events: none;
    transition: color var(--transition-speed) ease, opacity var(--transition-speed) ease;
  }

  .search-input-wrapper:focus-within .search-icon-left {
    color: var(--text-primary);
    opacity: 1;
  }

  .search-input {
    width: 100%;
    padding: 0.75rem 1.25rem 0.75rem 2.6rem;
    border-radius: 999px;
    border: 1px solid var(--border-color);
    background-color: var(--bg-secondary);
    color: var(--text-primary);
    font-family: inherit;
    font-size: 0.95rem;
    outline: none;
    box-shadow: inset 0 1px 2px rgba(0,0,0,0.02);
    transition: border-color var(--transition-speed) ease, 
                box-shadow var(--transition-speed) ease,
                background-color var(--transition-speed) ease;
  }

  .search-input:focus {
    border-color: var(--text-primary);
    background-color: var(--bg-primary);
    box-shadow: 0 0 0 3px var(--accent-light);
  }

  .search-submit-btn {
    padding: 0.75rem 1.75rem;
    border-radius: 999px;
    white-space: nowrap;
    font-weight: 600;
    flex-shrink: 0;
    box-shadow: var(--shadow-sm);
    transition: all var(--transition-speed) ease;
  }

  .search-submit-btn:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  .search-submit-btn:active {
    transform: translateY(0);
  }

  @media (max-width: 480px) {
    .search-submit-btn {
      padding: 0.75rem 1.25rem;
    }
  }

  .directory-section {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    padding: 1rem 0;
  }

  @media (min-width: 768px) {
    .directory-section {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
  }

  .directory-column {
    background-color: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-speed) ease, box-shadow var(--transition-speed) ease;
  }

  .directory-column:hover {
    box-shadow: var(--shadow-md);
  }

  .directory-column h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 1.25rem;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 0.75rem;
  }

  .author-links, .tag-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .author-badge, .tag-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.85rem;
    border-radius: 9999px;
    font-size: 0.85rem;
    font-weight: 500;
    background-color: var(--bg-secondary);
    color: var(--text-secondary);
    border: 1px solid var(--border-color);
    transition: all var(--transition-speed) ease;
  }

  .author-badge:hover, .author-badge.active,
  .tag-badge:hover, .tag-badge.active {
    background-color: var(--text-primary);
    color: var(--bg-primary);
    border-color: var(--text-primary);
    transform: translateY(-1px);
    box-shadow: var(--shadow-sm);
  }

  .author-badge:active, .tag-badge:active {
    transform: translateY(0);
  }

  .empty-text {
    font-size: 0.85rem;
    color: var(--text-secondary);
    font-style: italic;
    padding: 0.5rem 0;
  }

  .results-section {
    padding-top: 1.5rem;
  }

  .results-heading {
    font-size: 1.35rem;
    font-weight: 600;
    margin-bottom: 1.25rem;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .no-results {
    padding: 5rem 1.5rem;
    text-align: center;
    background-color: var(--bg-card);
    border: 1px dashed var(--border-color);
    border-radius: 16px;
    box-shadow: var(--shadow-sm);
    max-width: 500px;
    margin: 2rem auto;
  }

  .no-results-emoji {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    display: block;
    animation: pulse 2s infinite ease-in-out;
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 0.7; }
    50% { transform: scale(1.1); opacity: 1; }
  }

  .no-results h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
  }

  .no-results p {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.5;
  }
</style>
