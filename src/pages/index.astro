---
import { env } from 'cloudflare:workers';
import BaseLayout from '../layouts/BaseLayout.astro';
import TagFilter from '../components/TagFilter.astro';
import ImageCard from '../components/ImageCard.astro';
import { fetchGalleryBatch, parseGalleryBatchParams } from '../lib/gallery-feed';

if (!env || !env.DB) {
  return new Response('D1 DB binding "DB" is not configured. Please bind your database in wrangler.jsonc.', { status: 500 });
}

const activeTag = Astro.url.searchParams.get('tag');
const activeAuthor = Astro.url.searchParams.get('author');

// Fetch all distinct authors for listing
const authorsQuery = await env.DB.prepare('SELECT DISTINCT author FROM images WHERE published = 1 ORDER BY author ASC').all();
const authorsList = authorsQuery.results.map((r: any) => r.author);
const authorSet = new Set(authorsList.map((a: string) => a.toLowerCase()));

// 1. Fetch tags for TagFilter component (and filter out author handles)
const tagsQuery = await env.DB.prepare('SELECT name FROM tags ORDER BY name ASC').all();
const tagsList = tagsQuery.results.map((t: any) => t.name).filter((name: string) => !authorSet.has(name.toLowerCase()));

// Fetch a bounded first batch. URL-supplied offsets and limits never alter the initial page.
const initialParams = new URLSearchParams();
if (activeTag) initialParams.set('tag', activeTag);
if (activeAuthor) initialParams.set('author', activeAuthor);
const batchOptions = parseGalleryBatchParams(initialParams);
const { items: images, hasMore } = await fetchGalleryBatch(env.DB, batchOptions);

const formattedImages = images.map((img: any) => ({
  ...img,
  tags: img.tags_list 
    ? img.tags_list.split(',').filter((tag: string) => !authorSet.has(tag.trim().toLowerCase()))
    : []
}));

const pageTitle = activeTag 
  ? `分類 #${activeTag} - Twitter 照片牆` 
  : (activeAuthor ? `博主 @${activeAuthor} - Twitter 照片牆` : "極簡 Twitter 照片牆");
---

<BaseLayout title={pageTitle}>
  <div style="margin-top: 1.5rem;"></div>

  <!-- Authors Filter -->
  <div class="filter-section-title">👤 依博主篩選</div>
  <div class="author-filter-container">
    <div class="author-list">
      <a 
        href="/" 
        class={`tag-badge ${!activeAuthor ? 'active' : ''}`}
      >
        全部
      </a>
      {authorsList.map((author) => (
        <a 
          href={`/?author=${encodeURIComponent(author)}`} 
          class={`tag-badge ${activeAuthor === author ? 'active' : ''}`}
        >
          @{author}
        </a>
      ))}
    </div>
  </div>

  <!-- Tags Filter -->
  <div class="filter-section-title" style="margin-top: 1rem;">🏷️ 依標籤篩選</div>
  <TagFilter activeTag={activeTag} tags={tagsList} />

  {formattedImages.length > 0 && (
    <div class="filter-bar">
      <div class="media-filter-container">
        <button type="button" class="media-filter-btn active" data-media-type="all">全部</button>
        <button type="button" class="media-filter-btn" data-media-type="photo">📷 僅相片</button>
        <button type="button" class="media-filter-btn" data-media-type="video">🎥 僅影片</button>
      </div>
      <div class="sort-filter-container">
        <details class="custom-dropdown" id="sort-dropdown">
          <summary class="dropdown-trigger">
            <span class="dropdown-trigger-text">🕒 最新優先</span>
            <span class="dropdown-arrow">▼</span>
          </summary>
          <div class="dropdown-menu">
            <button type="button" class="dropdown-item active" data-value="newest">🕒 最新優先</button>
            <button type="button" class="dropdown-item" data-value="oldest">⌛ 最舊優先</button>
          </div>
        </details>
      </div>
    </div>
  )}

  {formattedImages.length > 0 ? (
    <>
      <div
        class="image-grid"
        data-offset={formattedImages.length}
        data-has-more={hasMore ? 'true' : 'false'}
      >
        {formattedImages.map((image, index) => (
          <ImageCard image={image} index={index} />
        ))}
      </div>
      <div id="gallery-sentinel" aria-hidden="true"></div>
      <div id="gallery-status" role="status" aria-live="polite" hidden></div>
      <button id="gallery-retry" type="button" class="btn btn-primary" hidden>重試載入</button>
      <div id="empty-media-state" class="empty-state" style="display: none; margin-top: 2rem;">
        <p class="empty-emoji">🍃</p>
        <h3>這裡空空如也</h3>
        <p>沒有找到符合該媒體類型的貼文。</p>
      </div>
    </>
  ) : (
    <div class="empty-state">
      <p class="empty-emoji">🍃</p>
      <h3>這裡空空如也</h3>
      <p>沒有找到符合該標籤的相片，請前往管理後台新增圖片。</p>
      <a href="/admin" class="btn btn-primary" style="margin-top: 1rem;">前往管理頁</a>
    </div>
  )}
</BaseLayout>

<script>
  import { GALLERY_BATCH_LIMIT, INITIAL_GALLERY_LIMIT } from '../lib/gallery-feed';

  // Restore liked state from localStorage on load
  function restoreLikes() {
    const likedImages = JSON.parse(localStorage.getItem('liked-images') || '[]');
    likedImages.forEach((id: number) => {
      const card = document.querySelector(`.image-card[data-id="${id}"]`);
      if (card) {
        const btn = card.querySelector('.like-button');
        if (btn) btn.classList.add('liked');
      }
    });
  }

  // Setup click listeners for like buttons
  function setupLikes() {
    document.querySelectorAll('.image-card').forEach((card) => {
      if ((card as HTMLElement).dataset.likeInitialized === 'true') return;

      const imgId = card.getAttribute('data-id');
      const likeBtn = card.querySelector('.like-button');
      const likeCountSpan = card.querySelector('.like-count');

      if (!likeBtn || !likeCountSpan || imgId === null) return;
      (card as HTMLElement).dataset.likeInitialized = 'true';

      likeBtn.addEventListener('click', async () => {
        const likedImages = JSON.parse(localStorage.getItem('liked-images') || '[]');
        const idNum = parseInt(imgId, 10);
        const isLiked = likedImages.includes(idNum);
        const action = isLiked ? 'unlike' : 'like';

        try {
          if (action === 'like') {
            likeBtn.classList.add('liked');
          } else {
            likeBtn.classList.remove('liked');
          }

          const response = await fetch(`/api/likes/${imgId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action })
          });
          const data = await response.json();
          if (data.success) {
            likeCountSpan.textContent = data.likes;
            if (action === 'like') {
              likedImages.push(idNum);
            } else {
              const idx = likedImages.indexOf(idNum);
              if (idx > -1) likedImages.splice(idx, 1);
            }
            localStorage.setItem('liked-images', JSON.stringify(likedImages));
          } else {
            // Revert state
            if (action === 'like') {
              likeBtn.classList.remove('liked');
            } else {
              likeBtn.classList.add('liked');
            }
          }
        } catch (err) {
          console.error(`Failed to ${action} image:`, err);
          // Revert state
          if (action === 'like') {
            likeBtn.classList.remove('liked');
          } else {
            likeBtn.classList.add('liked');
          }
        }
      });
    });
  }

  function applyMediaFilter() {
    const container = document.querySelector('.media-filter-container');
    if (!container) return;

    const filterType = container.querySelector<HTMLElement>('.media-filter-btn.active')?.dataset.mediaType ?? 'all';
    const cards = document.querySelectorAll('.image-card') as NodeListOf<HTMLElement>;
    const emptyState = document.getElementById('empty-media-state');
    let visibleCount = 0;

    cards.forEach((card) => {
      const hasPhoto = card.dataset.hasPhoto === 'true';
      const hasVideo = card.dataset.hasVideo === 'true';
      const matches = filterType === 'all'
        || (filterType === 'photo' && hasPhoto)
        || (filterType === 'video' && hasVideo);

      card.style.display = matches ? '' : 'none';
      if (matches) visibleCount++;
    });

    if (emptyState) emptyState.style.display = visibleCount === 0 ? 'block' : 'none';
  }

  // Setup media filtering (All / Photo / Video)
  function setupMediaFilter() {
    const container = document.querySelector('.media-filter-container');
    if (!container) return;

    const buttons = container.querySelectorAll('.media-filter-btn');
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        buttons.forEach((button) => button.classList.remove('active'));
        btn.classList.add('active');
        applyMediaFilter();
      });
    });
  }

  function setupGalleryFeed() {
    const dropdown = document.getElementById('sort-dropdown') as HTMLDetailsElement | null;
    const grid = document.querySelector<HTMLElement>('.image-grid');
    const sentinel = document.getElementById('gallery-sentinel');
    const status = document.getElementById('gallery-status');
    const retry = document.getElementById('gallery-retry') as HTMLButtonElement | null;
    if (!dropdown || !grid || !sentinel || !status || !retry) return;

    const triggerText = dropdown.querySelector('.dropdown-trigger-text');
    const items = dropdown.querySelectorAll('.dropdown-item');
    const pageParams = new URLSearchParams(window.location.search);
    const activeTag = pageParams.get('tag');
    const activeAuthor = pageParams.get('author');
    let offset = Number(grid.dataset.offset ?? 0);
    let hasMore = grid.dataset.hasMore === 'true';
    let loading = false;
    let pendingReset = false;
    let retryReset = false;
    let sort: 'newest' | 'oldest' = 'newest';

    async function fetchBatch({ reset }: { reset: boolean }) {
      if (loading) {
        if (reset) pendingReset = true;
        return;
      }
      if (!reset && !hasMore) return;

      loading = true;
      retry.hidden = true;
      status.hidden = false;
      status.textContent = '載入中…';

      try {
        const params = new URLSearchParams({
          offset: String(reset ? 0 : offset),
          limit: String(reset ? INITIAL_GALLERY_LIMIT : GALLERY_BATCH_LIMIT),
          sort,
        });
        if (activeTag) params.set('tag', activeTag);
        if (activeAuthor) params.set('author', activeAuthor);

        const response = await fetch(`/api/gallery?${params}`);
        if (!response.ok) throw new Error(`Gallery request failed: ${response.status}`);

        const fragmentDocument = new DOMParser().parseFromString(await response.text(), 'text/html');
        const batch = fragmentDocument.querySelector<HTMLElement>('.gallery-batch');
        if (!batch) throw new Error('Gallery batch is missing');

        const cards = Array.from(batch.querySelectorAll<HTMLElement>('.image-card'));
        if (reset) grid.replaceChildren(...cards);
        else grid.append(...cards);

        const count = Number(batch.dataset.count ?? cards.length);
        offset = (reset ? 0 : offset) + count;
        hasMore = batch.dataset.hasMore === 'true';
        grid.dataset.offset = String(offset);
        grid.dataset.hasMore = String(hasMore);
        retryReset = false;
        restoreLikes();
        setupLikes();
        applyMediaFilter();
        document.dispatchEvent(new CustomEvent('gallery:updated'));

        status.textContent = hasMore ? '' : '已載入全部內容';
        status.hidden = hasMore;
        if (hasMore) observer.observe(sentinel);
        else observer.disconnect();
      } catch (error) {
        console.error('Failed to load gallery batch:', error);
        retryReset = reset;
        retry.hidden = false;
        status.hidden = false;
        status.textContent = '載入失敗';
      } finally {
        loading = false;
        if (pendingReset) {
          pendingReset = false;
          void fetchBatch({ reset: true });
        }
      }
    }

    const observer = new IntersectionObserver(
      (entries) => {
        if (entries.some((entry) => entry.isIntersecting)) {
          void fetchBatch({ reset: false });
        }
      },
      { rootMargin: '800px 0px' },
    );

    if (hasMore) observer.observe(sentinel);
    retry.addEventListener('click', () => void fetchBatch({ reset: retryReset }));

    items.forEach((item) => {
      item.addEventListener('click', () => {
        const sortValue = item.getAttribute('data-value');
        if (sortValue !== 'newest' && sortValue !== 'oldest') return;

        items.forEach((i) => i.classList.remove('active'));
        item.classList.add('active');
        if (triggerText) triggerText.textContent = item.textContent || '';
        dropdown.removeAttribute('open');
        sort = sortValue;
        void fetchBatch({ reset: true });
      });
    });

    document.addEventListener('click', (e) => {
      if (!dropdown.contains(e.target as Node)) {
        dropdown.removeAttribute('open');
      }
    });
  }

  // Initial setup
  restoreLikes();
  setupLikes();
  setupMediaFilter();
  setupGalleryFeed();
</script>

<style>
  .filter-section-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.4rem;
  }

  .author-filter-container {
    padding: 0.5rem 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior-x: contain;
    width: 100%;
    max-width: 100%;
    margin-bottom: 0.5rem;
  }
  .author-filter-container::-webkit-scrollbar {
    height: 6px;
  }
  .author-filter-container::-webkit-scrollbar-track {
    background: transparent;
  }
  .author-filter-container::-webkit-scrollbar-thumb {
    background: var(--border-color);
    border-radius: 3px;
  }
  .author-filter-container::-webkit-scrollbar-thumb:hover {
    background: var(--text-secondary);
  }
  @media (max-width: 800px) {
    .author-filter-container {
      scrollbar-width: none;
    }
    .author-filter-container::-webkit-scrollbar {
      display: none;
    }
  }

  .author-list {
    display: flex;
    gap: 0.6rem;
    white-space: nowrap;
    padding-bottom: 0.5rem;
  }

  .filter-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 1rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
    gap: 0.5rem;
    width: 100%;
  }

  .media-filter-container {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .custom-dropdown {
    position: relative;
    display: inline-block;
  }
  .custom-dropdown[open] {
    z-index: 10;
  }
  .dropdown-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.85rem;
    background-color: var(--bg-secondary);
    color: var(--text-secondary);
    border: 1px solid var(--border-color);
    cursor: pointer;
    list-style: none; /* Hide default summary marker */
    user-select: none;
    transition: all var(--transition-speed) ease;
  }
  .dropdown-trigger::-webkit-details-marker {
    display: none; /* Hide Safari default marker */
  }
  .dropdown-trigger:hover {
    background-color: var(--accent-light);
    color: var(--text-primary);
    border-color: var(--text-primary);
  }
  .dropdown-arrow {
    font-size: 0.65rem;
    transition: transform 0.2s ease;
    color: var(--text-secondary);
  }
  .custom-dropdown[open] .dropdown-arrow {
    transform: rotate(180deg);
  }
  .dropdown-menu {
    position: absolute;
    top: calc(100% + 0.35rem);
    right: 0;
    background-color: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    box-shadow: var(--shadow-md);
    padding: 0.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 120px;
    z-index: 100;
  }
  .dropdown-item {
    display: flex;
    align-items: center;
    width: 100%;
    padding: 0.4rem 0.8rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
    background: transparent;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    text-align: left;
    white-space: nowrap;
    font-family: inherit;
    transition: all var(--transition-speed) ease;
  }
  .dropdown-item:hover {
    background-color: var(--bg-secondary);
    color: var(--text-primary);
  }
  .dropdown-item.active {
    background-color: var(--text-primary);
    color: var(--bg-primary);
  }
  .media-filter-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.85rem;
    background-color: var(--bg-secondary);
    color: var(--text-secondary);
    border: 1px solid var(--border-color);
    cursor: pointer;
    transition: all var(--transition-speed) ease;
    font-family: inherit;
  }
  .media-filter-btn:hover, .media-filter-btn.active {
    background-color: var(--text-primary);
    color: var(--bg-primary);
    border-color: var(--text-primary);
  }

  .empty-state {
    padding: 5rem 1rem;
    text-align: center;
    border: 1px dashed var(--border-color);
    border-radius: 12px;
    margin-top: 2rem;
  }

  .empty-emoji {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .empty-state h3 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .empty-state p {
    color: var(--text-secondary);
    font-size: 0.9rem;
    max-width: 400px;
    margin: 0 auto;
  }

  #gallery-sentinel {
    height: 1px;
  }

  #gallery-status,
  #gallery-retry {
    display: block;
    margin: 1.5rem auto 0;
    text-align: center;
  }

  #gallery-status[hidden],
  #gallery-retry[hidden] {
    display: none;
  }
</style>
