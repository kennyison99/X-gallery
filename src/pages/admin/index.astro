import { env } from 'cloudflare:workers';
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/admin.css';
import AdminDashboardTabs from '../../components/admin/AdminDashboardTabs.astro';
import AdminOverview from '../../components/admin/AdminOverview.astro';
import AdminUploadPanel from '../../components/admin/AdminUploadPanel.astro';
import AdminPostManager from '../../components/admin/AdminPostManager.astro';
import AdminCrawlerPanel from '../../components/admin/AdminCrawlerPanel.astro';
import AdminAutoTagPanel from '../../components/admin/AdminAutoTagPanel.astro';

if (!env || !env.DB) {
  return new Response('D1 DB binding not configured. Please bind your database in wrangler.jsonc.', { status: 500 });
}

// 1. Fetch all distinct authors first
let authorSet = new Set<string>();
try {
  const authorsQuery = await env.DB.prepare('SELECT DISTINCT author FROM images').all();
  const authorsList = (authorsQuery.results || []).map((r: any) => r.author);
  authorSet = new Set(authorsList.map((a: string) => a.toLowerCase()));
} catch (err) {
  console.error('Error fetching authors for admin:', err);
}

// 2. Fetch all existing tags for reusable selection and filter out author handles
let allTags = [];
try {
  const tagsQuery = await env.DB.prepare('SELECT * FROM tags ORDER BY name ASC').all();
  allTags = (tagsQuery.results || []).filter((tag: any) => !authorSet.has(tag.name.toLowerCase()));
} catch (err) {
  console.error('Error fetching tags for admin:', err);
}

// 3. Fetch all images/posts for management list
let images = [];
try {
  const query = `
    SELECT i.*, group_concat(t.name) as tags_list
    FROM images i
    LEFT JOIN image_tags it ON i.id = it.image_id
    LEFT JOIN tags t ON it.tag_id = t.id
    GROUP BY i.id
    ORDER BY i.created_at DESC
  `;
  const { results } = await env.DB.prepare(query).all();
  images = results || [];
} catch (err) {
  console.error('Error fetching images for admin:', err);
}

// 3. Fetch crawl accounts
let crawlAccounts = [];
try {
  const { results } = await env.DB.prepare('SELECT * FROM crawl_accounts ORDER BY created_at DESC').all();
  crawlAccounts = (results || []).map((a: any) => {
    // Build "最近一次" display text from last crawl metadata
    let lastCrawlText = '';
    if (a.last_crawled_at) {
      const d = new Date(a.last_crawled_at);
      const dateStr = `${d.getDate()}/${d.getMonth() + 1}/${d.getFullYear()}`;
      const typeLabel = a.last_crawl_type === 'manual' ? '手動' : '自動';
      const modeLabel = a.last_crawl_mode === 'all' ? '全歷史' : '最新';
      const count = a.last_crawl_count ?? 0;
      lastCrawlText = `於 ${dateStr} ${typeLabel}爬取${modeLabel} (+${count})`;
    }
    return { ...a, lastCrawlText };
  });
} catch (err) {
  console.error('Error fetching crawl accounts:', err);
}

const VIDEO_EXTS = new Set(['.mp4', '.webm', '.mov', '.m4v']);
const isVideoKey = (key: string) => VIDEO_EXTS.has((key.toLowerCase().match(/\.[a-z0-9]+$/)?.[0] ?? ''));

const formattedImages = images.map((img: any) => {
  // Calculate remaining time for pending images (3 days from created_at)
  let remainingText = '';
  let isCritical = false;
  if (img.published === 0) {
    const createdTime = new Date(img.created_at).getTime();
    const expireTime = createdTime + (3 * 24 * 60 * 60 * 1000);
    const remainingMs = expireTime - Date.now();
    if (remainingMs <= 0) {
      remainingText = '即將刪除';
      isCritical = true;
    } else {
      const remainingHours = Math.ceil(remainingMs / (1000 * 60 * 60));
      if (remainingHours < 24) {
        remainingText = `剩餘 ${remainingHours} 小時`;
        isCritical = true;
      } else {
        const remainingDays = Math.floor(remainingHours / 24);
        const extraHours = remainingHours % 24;
        remainingText = `剩餘 ${remainingDays} 天 ${extraHours} 小時`;
      }
    }
  }

  // Calculate media types
  const keys = img.r2_keys ? img.r2_keys.split(',').map((k: string) => k.trim()).filter(Boolean) : [];
  const hasPhoto = keys.some((k: string) => !isVideoKey(k));
  const hasVideo = keys.some((k: string) => isVideoKey(k));

  return {
    ...img,
    tags: img.tags_list ? img.tags_list.split(',').filter((tag: string) => !authorSet.has(tag.trim().toLowerCase())) : [],
    remainingText,
    isCritical,
    hasPhoto,
    hasVideo
  };
});
