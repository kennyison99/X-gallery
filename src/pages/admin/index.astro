<BaseLayout title="CMS 後台管理 - Twitter 照片牆">
  <div class="admin-container">
    <div class="admin-header">
      <h1>CMS 管理後台</h1>
      <p>上傳多張相片作為單一卡片貼文到 R2，並管理所有照片與標籤資料。</p>
    </div>

    <AdminDashboardTabs />

    <AdminOverview
      totalPosts={formattedImages.length}
      pendingPosts={formattedImages.filter((image) => image.published === 0).length}
      totalAccounts={crawlAccounts.length}
      enabledAccounts={crawlAccounts.filter((account) => account.enabled === 1).length}
    />

    <div class="admin-grid">
      <AdminUploadPanel allTags={allTags} />

      <AdminPostManager images={formattedImages} />

      <AdminAutoTagPanel />

      <AdminCrawlerPanel accounts={crawlAccounts} />
    </div>
  </div>
</BaseLayout>

<script>
  import { formatAuthorName, resolveAdminTab } from '../../lib/admin-dashboard';

  // Lazily load post manager thumbnails only when the posts tab is first
  // activated, so hidden panels don't trigger R2 fetches on page load.
  let postsMediaHydrated = false;
  function hydratePostMedia() {
    if (postsMediaHydrated) return;
    postsMediaHydrated = true;
    document.querySelectorAll<HTMLImageElement | HTMLVideoElement>('#panel-posts [data-src]').forEach((el) => {
      el.src = el.dataset.src!;
      el.removeAttribute('data-src');
    });
  }

  function activateAdminTab() {
    const activeTab = resolveAdminTab(window.location.hash);
    if (window.location.hash !== `#${activeTab}`) {
      history.replaceState(null, '', `#${activeTab}`);
    }

    document.querySelectorAll<HTMLElement>('[data-admin-tab]').forEach((tab) => {
      const selected = tab.dataset.adminTab === activeTab;
      tab.classList.toggle('active', selected);
      tab.setAttribute('aria-selected', String(selected));
      tab.tabIndex = selected ? 0 : -1;
    });

    document.querySelectorAll<HTMLElement>('[data-admin-panel]').forEach((panel) => {
      panel.hidden = panel.dataset.adminPanel !== activeTab;
    });

    if (activeTab === 'posts') hydratePostMedia();
  }

  window.addEventListener('hashchange', activateAdminTab);
  activateAdminTab();

  document.querySelector('[role="tablist"]')?.addEventListener('keydown', (event) => {
    if (!(event instanceof KeyboardEvent) || !['ArrowLeft', 'ArrowRight'].includes(event.key)) return;
    const tabs = [...document.querySelectorAll<HTMLAnchorElement>('[data-admin-tab]')];
    const currentIndex = tabs.indexOf(document.activeElement as HTMLAnchorElement);
    if (currentIndex < 0) return;
    event.preventDefault();
    const direction = event.key === 'ArrowRight' ? 1 : -1;
    tabs[(currentIndex + direction + tabs.length) % tabs.length].focus();
  });

  document.querySelector('[data-post-status="pending"]')?.addEventListener('click', () => {
    document.getElementById('tab-pending')?.click();
  });

  import { runSequentialBatches } from '../../lib/batches.ts';

  // ---- R2 storage capacity widget ----
  function formatBytes(bytes: number): string {
    if (bytes < 1024) return `${bytes} B`;
    if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
    if (bytes < 1024 * 1024 * 1024) return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
    return `${(bytes / (1024 * 1024 * 1024)).toFixed(2)} GB`;
  }

  const storageBarFill = document.getElementById('storage-bar-fill');
  const storageUsed = document.getElementById('storage-used');
  const storageWarning = document.getElementById('storage-warning');
  const storageReconcileBtn = document.getElementById('storage-reconcile-btn') as HTMLButtonElement | null;

  async function refreshStorage(reconcile = false) {
    try {
      const res = await fetch('/api/storage-stats', reconcile ? { method: 'POST' } : {});
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || '讀取失敗');
      const total = Number(data.total_bytes || 0);
      const limit = Number(data.limit_bytes || 10 * 1024 * 1024 * 1024);
      const pct = Math.min(100, (total / limit) * 100);

      if (storageBarFill) {
        storageBarFill.style.width = `${pct}%`;
        storageBarFill.classList.remove('warn', 'critical');
        if (pct >= 90) storageBarFill.classList.add('critical');
        else if (pct >= 80) storageBarFill.classList.add('warn');
      }
      if (storageUsed) {
        storageUsed.textContent = `${formatBytes(total)} / ${formatBytes(limit)} (${pct.toFixed(1)}%)`;
      }
      if (storageWarning) {
        if (pct >= 95) {
          storageWarning.textContent = '⚠️ 已達 95% 上限，新上傳將被拒絕。請先刪除舊資料。';
          storageWarning.hidden = false;
        } else if (pct >= 90) {
          storageWarning.textContent = '⚠️ 容量已超過 90%，請留意用量。';
          storageWarning.hidden = false;
        } else if (pct >= 80) {
          storageWarning.textContent = '提醒：容量已超過 80%。';
          storageWarning.hidden = false;
        } else {
          storageWarning.hidden = true;
        }
      }
    } catch (err: any) {
      if (storageUsed) storageUsed.textContent = `讀取失敗：${err.message}`;
    }
  }

  refreshStorage();
  storageReconcileBtn?.addEventListener('click', async () => {
    if (!storageReconcileBtn) return;
    storageReconcileBtn.disabled = true;
    storageReconcileBtn.textContent = '計算中…';
    await refreshStorage(true);
    storageReconcileBtn.disabled = false;
    storageReconcileBtn.textContent = '重新計算';
  });

  // Bulk action UI bindings
  const selectAllCheckbox = document.getElementById('select-all-checkbox') as HTMLInputElement | null;
  const bulkActionsBar = document.getElementById('bulk-actions-bar');
  const selectedCountDisplay = document.getElementById('selected-count-display');
  const bulkDeleteBtn = document.getElementById('bulk-delete-btn') as HTMLButtonElement | null;
  const bulkDeleteProgress = document.getElementById('bulk-delete-progress');
  const bulkDeleteProgressBar = document.getElementById('bulk-delete-progress-bar') as HTMLProgressElement | null;
  const bulkDeleteProgressText = document.getElementById('bulk-delete-progress-text');


  const tabPublished = document.getElementById('tab-published');
  const tabPending = document.getElementById('tab-pending');
  let activeTab = 'published';

  const autoTagBtn = document.getElementById('auto-tag-btn') as HTMLButtonElement | null;
  const autoTagProgress = document.getElementById('auto-tag-progress');
  const autoTagProgressBar = document.getElementById('auto-tag-progress-bar') as HTMLProgressElement | null;
  const autoTagProgressText = document.getElementById('auto-tag-progress-text');

  function updateOperationProgress(
    container: HTMLElement | null,
    progress: HTMLProgressElement | null,
    text: HTMLElement | null,
    current: number,
    total: number,
    message: string
  ) {
    if (container) container.hidden = false;
    if (progress) {
      progress.max = Math.max(total, 1);
      progress.value = current;
    }
    if (text) text.textContent = message;
  }

  function updateBulkActionsState() {
    const checkedCheckboxes = document.querySelectorAll('.image-select-checkbox:checked');
    const checkedCount = checkedCheckboxes.length;

    if (selectedCountDisplay) {
      selectedCountDisplay.textContent = `已選擇 ${checkedCount} 筆照片`;
    }

    if (bulkActionsBar) {
      if (checkedCount > 0) {
        bulkActionsBar.classList.add('visible');
      } else {
        bulkActionsBar.classList.remove('visible');
      }
    }

    if (selectAllCheckbox) {
      const visibleCheckboxes = (typeof filteredRows !== 'undefined' && filteredRows) ? filteredRows.map(row => row.querySelector('.image-select-checkbox') as HTMLInputElement).filter(Boolean) : [];
      const checkedVisibleCount = visibleCheckboxes.filter(cb => cb.checked).length;
      selectAllCheckbox.checked = visibleCheckboxes.length > 0 && checkedVisibleCount === visibleCheckboxes.length;
    }
  }

  // UI interactions for file input
  const fileInput = document.getElementById('image-file') as HTMLInputElement | null;
  const fileNameDisplay = document.querySelector('.file-name-display');
  const uploadPrompt = document.querySelector('.upload-prompt');
  const fileRequiredStar = document.getElementById('file-required-star');
  const formTitleText = document.getElementById('form-title-text');
  const cancelBtn = document.getElementById('cancel-edit-btn') as HTMLButtonElement | null;
  const newTagsInput = document.getElementById('new-tags') as HTMLInputElement | null;

  const titleInput = document.getElementById('image-title') as HTMLInputElement | null;
  const descInput = document.getElementById('image-description') as HTMLTextAreaElement | null;
  const authorInput = document.getElementById('image-author') as HTMLInputElement | null;
  const authorDisplayNameInput = document.getElementById('image-author-display-name') as HTMLInputElement | null;
  const authorUrlInput = document.getElementById('image-author-url') as HTMLInputElement | null;
  const postUrlInput = document.getElementById('image-post-url') as HTMLInputElement | null;

  // Previews elements
  const previewContainer = document.getElementById('image-preview-container');
  const existingPreviewSection = document.getElementById('existing-images-preview');
  const existingGrid = document.getElementById('existing-images-grid');
  const newPreviewSection = document.getElementById('new-images-preview');
  const newGrid = document.getElementById('new-images-grid');

  let isEditMode = false;
  let editingId: string | null = null;

  // Keep track of files and existing keys
  let remainingExistingKeys: string[] = [];
  let selectedNewFiles: File[] = [];

  // Render new selected files preview
  function renderNewFilesPreview() {
    if (!newGrid || !newPreviewSection || !previewContainer) return;
    newGrid.innerHTML = '';
    
    if (selectedNewFiles.length > 0) {
      newPreviewSection.style.display = 'block';
      previewContainer.style.display = 'block';
      
      selectedNewFiles.forEach((file, index) => {
        const itemWrapper = document.createElement('div');
        itemWrapper.style.position = 'relative';
        itemWrapper.style.width = '60px';
        itemWrapper.style.height = '60px';
        
        const img = document.createElement('img');
        img.style.width = '60px';
        img.style.height = '60px';
        img.style.objectFit = 'cover';
        img.style.borderRadius = '4px';
        img.style.border = '1px solid var(--border-color)';
        
        const removeBtn = document.createElement('button');
        removeBtn.type = 'button';
        removeBtn.innerHTML = '×';
        removeBtn.style.position = 'absolute';
        removeBtn.style.top = '-4px';
        removeBtn.style.right = '-4px';
        removeBtn.style.background = 'var(--heart-color)';
        removeBtn.style.color = 'white';
        removeBtn.style.border = 'none';
        removeBtn.style.borderRadius = '50%';
        removeBtn.style.width = '18px';
        removeBtn.style.height = '18px';
        removeBtn.style.fontSize = '10px';
        removeBtn.style.fontWeight = 'bold';
        removeBtn.style.cursor = 'pointer';
        removeBtn.style.display = 'flex';
        removeBtn.style.alignItems = 'center';
        removeBtn.style.justifyContent = 'center';
        removeBtn.style.padding = '0';
        
        removeBtn.addEventListener('click', () => {
          selectedNewFiles.splice(index, 1);
          renderNewFilesPreview();
          updateFileInputDisplay();
        });
        
        const reader = new FileReader();
        reader.onload = (e) => {
          img.src = e.target?.result as string;
        };
        reader.readAsDataURL(file);
        
        itemWrapper.appendChild(img);
        itemWrapper.appendChild(removeBtn);
        newGrid.appendChild(itemWrapper);
      });
    } else {
      newPreviewSection.style.display = 'none';
      if (remainingExistingKeys.length === 0) {
        previewContainer.style.display = 'none';
      }
    }
  }

  // Render existing images preview
  function renderExistingImagesPreview() {
    if (!existingGrid || !existingPreviewSection || !previewContainer) return;
    existingGrid.innerHTML = '';
    
    if (remainingExistingKeys.length > 0) {
      existingPreviewSection.style.display = 'block';
      previewContainer.style.display = 'block';
      
      remainingExistingKeys.forEach((key, index) => {
        const itemWrapper = document.createElement('div');
        itemWrapper.style.position = 'relative';
        itemWrapper.style.width = '60px';
        itemWrapper.style.height = '60px';
        
        const img = document.createElement('img');
        img.src = `/api/r2/${encodeURIComponent(key)}`;
        img.style.width = '60px';
        img.style.height = '60px';
        img.style.objectFit = 'cover';
        img.style.borderRadius = '4px';
        img.style.border = '1px solid var(--border-color)';
        
        const removeBtn = document.createElement('button');
        removeBtn.type = 'button';
        removeBtn.innerHTML = '×';
        removeBtn.style.position = 'absolute';
        removeBtn.style.top = '-4px';
        removeBtn.style.right = '-4px';
        removeBtn.style.background = 'var(--heart-color)';
        removeBtn.style.color = 'white';
        removeBtn.style.border = 'none';
        removeBtn.style.borderRadius = '50%';
        removeBtn.style.width = '18px';
        removeBtn.style.height = '18px';
        removeBtn.style.fontSize = '10px';
        removeBtn.style.fontWeight = 'bold';
        removeBtn.style.cursor = 'pointer';
        removeBtn.style.display = 'flex';
        removeBtn.style.alignItems = 'center';
        removeBtn.style.justifyContent = 'center';
        removeBtn.style.padding = '0';
        
        removeBtn.addEventListener('click', () => {
          remainingExistingKeys.splice(index, 1);
          renderExistingImagesPreview();
        });
        
        itemWrapper.appendChild(img);
        itemWrapper.appendChild(removeBtn);
        existingGrid.appendChild(itemWrapper);
      });
    } else {
      existingPreviewSection.style.display = 'none';
      if (selectedNewFiles.length === 0) {
        previewContainer.style.display = 'none';
      }
    }
  }

  function updateFileInputDisplay() {
    if (!fileNameDisplay) return;
    const count = selectedNewFiles.length;
    if (count > 0) {
      fileNameDisplay.textContent = `已選取 ${count} 個檔案`;
    } else {
      fileNameDisplay.textContent = '尚未選擇任何檔案';
    }
  }

  if (fileInput) {
    fileInput.addEventListener('change', () => {
      if (fileInput.files) {
        // Accumulate newly selected files
        Array.from(fileInput.files).forEach(file => {
          selectedNewFiles.push(file);
        });
        // Clear file input value so user can select the same file again
        fileInput.value = '';
        updateFileInputDisplay();
        renderNewFilesPreview();
      }
    });
  }

  function resetForm() {
    isEditMode = false;
    editingId = null;
    remainingExistingKeys = [];
    selectedNewFiles = [];
    
    if (uploadForm) uploadForm.reset();
    if (formTitleText) formTitleText.textContent = '發佈相片貼文';
    if (btnText) btnText.textContent = '確認上傳';
    if (cancelBtn) cancelBtn.style.display = 'none';
    if (fileInput) fileInput.required = true;
    if (fileRequiredStar) fileRequiredStar.style.display = 'inline';
    if (uploadPrompt) uploadPrompt.textContent = '點擊選擇照片 (可選多張)';
    if (fileNameDisplay) fileNameDisplay.textContent = '尚未選擇任何檔案';
    
    // Reset previews
    if (existingGrid) existingGrid.innerHTML = '';
    if (existingPreviewSection) existingPreviewSection.style.display = 'none';
    if (newGrid) newGrid.innerHTML = '';
    if (newPreviewSection) newPreviewSection.style.display = 'none';
    if (previewContainer) previewContainer.style.display = 'none';

    if (uploadMessage) {
      uploadMessage.textContent = '';
      uploadMessage.style.display = 'none';
    }
  }

  function enterEditMode(id: string, data: any) {
    isEditMode = true;
    editingId = id;
    selectedNewFiles = [];
    remainingExistingKeys = data.keys.split(',').map((k: string) => k.trim()).filter(Boolean);

    if (formTitleText) formTitleText.textContent = '修改相片貼文';
    if (btnText) btnText.textContent = '確認修改';
    if (cancelBtn) cancelBtn.style.display = 'inline-block';
    if (fileInput) {
      fileInput.required = false;
      fileInput.value = '';
    }
    if (fileRequiredStar) fileRequiredStar.style.display = 'none';
    if (uploadPrompt) uploadPrompt.textContent = '上傳新照片以附加至貼文 (可選多張)';
    if (fileNameDisplay) fileNameDisplay.textContent = '尚未選擇任何檔案';
    
    if (titleInput) titleInput.value = data.title;
    if (descInput) descInput.value = data.description;
    if (authorInput) authorInput.value = data.author;
    if (authorDisplayNameInput) authorDisplayNameInput.value = data.authorDisplayName;
    if (authorUrlInput) authorUrlInput.value = data.authorUrl;
    if (postUrlInput) postUrlInput.value = data.postUrl;

    // Check tags checkboxes
    document.querySelectorAll('input[name="existing_tags"]').forEach((cb) => {
      (cb as HTMLInputElement).checked = false;
    });

    const tagsArray = data.tags.split(',').map((t: string) => t.trim()).filter(Boolean);
    tagsArray.forEach((tag: string) => {
      const checkbox = document.querySelector(`input[name="existing_tags"][value="${tag}"]`) as HTMLInputElement | null;
      if (checkbox) checkbox.checked = true;
    });

    if (newTagsInput) newTagsInput.value = '';

    // Render previews
    renderExistingImagesPreview();
    renderNewFilesPreview();

    if (uploadMessage) {
      uploadMessage.textContent = '';
      uploadMessage.style.display = 'none';
    }
  }

  if (cancelBtn) {
    cancelBtn.addEventListener('click', resetForm);
  }

  // Hook up Edit buttons
  document.querySelectorAll('.edit-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-id');
      const title = btn.getAttribute('data-title') || '';
      const description = btn.getAttribute('data-description') || '';
      const author = btn.getAttribute('data-author') || '';
      const authorDisplayName = btn.getAttribute('data-author-display-name') || '';
      const authorUrl = btn.getAttribute('data-author-url') || '';
      const postUrl = btn.getAttribute('data-post-url') || '';
      const tags = btn.getAttribute('data-tags') || '';
      const keys = btn.getAttribute('data-keys') || '';
      
      if (id) {
        enterEditMode(id, { title, description, author, authorDisplayName, authorUrl, postUrl, tags, keys });
        window.location.hash = 'upload';
        requestAnimationFrame(() => uploadForm?.scrollIntoView({ behavior: 'smooth' }));
      }
    });
  });

  // Handle Form Upload / Modify
  const uploadForm = document.getElementById('upload-form') as HTMLFormElement | null;
  const submitBtn = document.querySelector('.btn-submit') as HTMLButtonElement | null;
  const btnText = document.querySelector('.btn-text');
  const loaderSpinner = document.querySelector('.loader-spinner') as HTMLElement | null;
  const uploadMessage = document.getElementById('upload-message');

  if (uploadForm && submitBtn && btnText && loaderSpinner && uploadMessage) {
    uploadForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Check if we have at least one image in total
      const totalImages = (isEditMode ? remainingExistingKeys.length : 0) + selectedNewFiles.length;
      if (totalImages === 0) {
        uploadMessage.textContent = '錯誤：貼文必須至少包含一張照片。';
        uploadMessage.className = 'form-message error';
        uploadMessage.style.display = 'block';
        return;
      }
      
      // Update loading UI
      submitBtn.disabled = true;
      btnText.textContent = isEditMode ? '正在修改中...' : '正在上傳中...';
      if (loaderSpinner) loaderSpinner.style.display = 'inline-block';
      uploadMessage.textContent = '';
      uploadMessage.className = 'form-message';
      uploadMessage.style.display = 'none';

      // 1. Prepare FormData
      const formData = new FormData();
      
      // Add manual selected files
      selectedNewFiles.forEach(file => {
        formData.append('file', file);
      });

      // Add existing keys to keep if in edit mode
      if (isEditMode) {
        formData.append('existing_keys', remainingExistingKeys.join(','));
      }

      formData.append('title', titleInput?.value || '');
      formData.append('description', descInput?.value || '');
      formData.append('author', authorInput?.value || '');
      formData.append('author_url', authorUrlInput?.value || '');
      formData.append('post_url', postUrlInput?.value || '');

      // Combine existing tags and new tags
      const checkedTags: string[] = [];
      document.querySelectorAll('input[name="existing_tags"]:checked').forEach((checkbox) => {
        checkedTags.push((checkbox as HTMLInputElement).value);
      });

      const newTagsRaw = newTagsInput?.value || '';

      const tagsCombined = [
        ...checkedTags,
        ...newTagsRaw.split(/[\s,]+/).map(t => t.trim().replace(/^#/, '')).filter(t => t.length > 0)
      ].join(',');

      formData.append('tags', tagsCombined);

      try {
        const url = isEditMode ? `/api/images/${editingId}` : '/api/images';
        const method = isEditMode ? 'PUT' : 'POST';

        const response = await fetch(url, {
          method: method,
          body: formData
        });

        const data = await response.json();
        
        if (response.ok && data.success) {
          uploadMessage.textContent = isEditMode ? '貼文修改成功！正在重新整理頁面...' : '貼文上傳成功！正在重新整理頁面...';
          uploadMessage.className = 'form-message success';
          uploadMessage.style.display = 'block';
          resetForm();
          
          setTimeout(() => {
            window.location.reload();
          }, 1500);
        } else {
          uploadMessage.textContent = `${isEditMode ? '修改' : '上傳'}失敗：${data.error || '未知錯誤'}`;
          uploadMessage.className = 'form-message error';
          uploadMessage.style.display = 'block';
          submitBtn.disabled = false;
          btnText.textContent = isEditMode ? '確認修改' : '確認上傳';
          if (loaderSpinner) loaderSpinner.style.display = 'none';
        }
      } catch (err) {
        console.error(err);
        uploadMessage.textContent = '網路或伺服器錯誤，請稍後再試。';
        uploadMessage.className = 'form-message error';
        uploadMessage.style.display = 'block';
        submitBtn.disabled = false;
        btnText.textContent = isEditMode ? '確認修改' : '確認上傳';
        if (loaderSpinner) loaderSpinner.style.display = 'none';
      }
    });
  }

  // Handle Deletion
  document.querySelectorAll('.delete-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const imgId = btn.getAttribute('data-id');
      if (!imgId) return;

      if (!confirm('你確定要刪除這張照片貼文嗎？此操作將會從資料庫與 Cloudflare R2 中永久刪除該貼文的所有照片！')) {
        return;
      }

      (btn as HTMLButtonElement).disabled = true;
      btn.textContent = '刪除中...';

      try {
        const response = await fetch(`/api/images/${imgId}`, {
          method: 'DELETE'
        });

        const data = await response.json();

        if (response.ok && data.success) {
          const row = document.querySelector(`.image-row[data-id="${imgId}"]`);
          if (row) {
            row.remove();
          }
          const remainingRows = document.querySelectorAll('.image-row');
          if (remainingRows.length === 0) {
            window.location.reload();
          }
          refreshStorage();
        } else {
          alert(`刪除失敗：${data.error || '未知錯誤'}`);
          (btn as HTMLButtonElement).disabled = false;
          btn.textContent = '刪除';
        }
      } catch (err) {
        console.error(err);
        alert('刪除失敗，伺服器發生錯誤。');
        (btn as HTMLButtonElement).disabled = false;
        btn.textContent = '刪除';
      }
    });
  });

  // =========== Crawl Accounts Management ===========
  const crawlUsernameInput = document.getElementById('crawl-username') as HTMLInputElement | null;
  const addCrawlBtn = document.getElementById('add-crawl-btn') as HTMLButtonElement | null;
  const crawlMessage = document.getElementById('crawl-message') as HTMLElement | null;
  const crawlAccountsList = document.getElementById('crawl-accounts-list');
  const crawlEmptyText = document.getElementById('crawl-empty-text');

  function showCrawlMessage(text: string, type: 'success' | 'error') {
    if (!crawlMessage) return;
    crawlMessage.textContent = text;
    crawlMessage.className = `form-message ${type}`;
    crawlMessage.style.display = 'block';
    setTimeout(() => {
      crawlMessage.style.display = 'none';
    }, 3000);
  }

  if (addCrawlBtn && crawlUsernameInput) {
    addCrawlBtn.addEventListener('click', async () => {
      const username = crawlUsernameInput.value.trim().replace(/^@/, '');
      if (!username) {
        showCrawlMessage('請輸入帳號名稱', 'error');
        return;
      }

      addCrawlBtn.disabled = true;
      addCrawlBtn.textContent = '新增中...';

      try {
        const res = await fetch('/api/crawl-accounts', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username })
        });
        const data = await res.json();

        if (res.ok && data.success) {
          showCrawlMessage(`已新增 @${username}`, 'success');
          crawlUsernameInput.value = '';
          
          // Add to DOM — insert at top (newest first, matching ORDER BY created_at DESC)
          if (crawlEmptyText) crawlEmptyText.remove();
          const item = document.createElement('div');
          item.className = 'crawl-account-item';
          item.setAttribute('data-username', username);
          item.innerHTML = `
            <div class="crawl-account-info">
              <span class="crawl-account-name">@${username}</span>
              <a href="https://x.com/${username}" target="_blank" rel="noopener noreferrer" class="crawl-account-link" title="前往 Twitter">↗</a>
            </div>
            <div class="crawl-account-settings" style="display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;">
              <label style="display: flex; align-items: center; gap: 0.25rem; font-size: 0.8rem; cursor: pointer; color: var(--text-secondary);">
                <input type="checkbox" class="toggle-enabled-cb" data-username="${username}" checked />
                <span>啟用自動爬取</span>
              </label>
              <label style="display: flex; align-items: center; gap: 0.25rem; font-size: 0.8rem; cursor: pointer; color: var(--text-secondary);">
                <input type="checkbox" class="toggle-crawlall-cb" data-username="${username}" />
                <span>爬取全部歷史圖片</span>
              </label>
              <button class="btn btn-danger remove-crawl-btn" data-username="${username}" style="font-size: 0.8rem; padding: 0.25rem 0.5rem; margin-left: 0.5rem;">移除</button>
            </div>
          `;
          crawlAccountsList?.prepend(item);
          
          // Attach remove handler
          item.querySelector('.remove-crawl-btn')?.addEventListener('click', handleRemoveCrawl);
          // Attach settings change handlers
          item.querySelectorAll('input[type="checkbox"]').forEach(cb => {
            cb.addEventListener('change', handleToggleCrawlSetting);
          });
        } else {
          showCrawlMessage(data.error || '新增失敗', 'error');
        }
      } catch (err) {
        showCrawlMessage('網路錯誤，請稍後再試', 'error');
      } finally {
        addCrawlBtn.disabled = false;
        addCrawlBtn.textContent = '新增帳號';
      }
    });
  }

  async function handleToggleCrawlSetting(this: HTMLInputElement) {
    const username = this.getAttribute('data-username');
    if (!username) return;

    const isEnabledToggle = this.classList.contains('toggle-enabled-cb');
    const isCrawlAllToggle = this.classList.contains('toggle-crawlall-cb');

    const payload: any = { username };
    if (isEnabledToggle) {
      payload.enabled = this.checked;
    } else if (isCrawlAllToggle) {
      payload.crawl_all = this.checked;
    }

    this.disabled = true;

    try {
      const res = await fetch('/api/crawl-accounts', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      const data = await res.json();

      if (!res.ok || !data.success) {
        this.checked = !this.checked;
        alert(`更新設定失敗：${data.error || '未知錯誤'}`);
      }
    } catch (err) {
      this.checked = !this.checked;
      alert('更新設定失敗，網路或伺服器錯誤。');
    } finally {
      this.disabled = false;
    }
  }

  async function handleRemoveCrawl(this: HTMLElement) {
    const username = this.getAttribute('data-username');
    if (!username) return;
    if (!confirm(`確定要移除 @${username} 嗎？`)) return;

    (this as HTMLButtonElement).disabled = true;
    this.textContent = '移除中...';

    try {
      const res = await fetch('/api/crawl-accounts', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username })
      });
      const data = await res.json();

      if (res.ok && data.success) {
        const item = document.querySelector(`.crawl-account-item[data-username="${username}"]`);
        if (item) item.remove();

        const remaining = document.querySelectorAll('.crawl-account-item');
        if (remaining.length === 0 && crawlAccountsList) {
          const empty = document.createElement('p');
          empty.className = 'empty-text';
          empty.id = 'crawl-empty-text';
          empty.textContent = '尚未新增任何爬取帳號。';
          crawlAccountsList.appendChild(empty);
        }
        showCrawlMessage(`已移除 @${username}`, 'success');
      } else {
        showCrawlMessage(data.error || '移除失敗', 'error');
        (this as HTMLButtonElement).disabled = false;
        this.textContent = '移除';
      }
    } catch (err) {
      showCrawlMessage('網路錯誤', 'error');
      (this as HTMLButtonElement).disabled = false;
      this.textContent = '移除';
    }
  }

  // Attach remove handlers to existing buttons
  document.querySelectorAll('.remove-crawl-btn').forEach(btn => {
    btn.addEventListener('click', handleRemoveCrawl);
  });

  // =========== Admin List Filtering and Pagination ===========
  const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
  const authorFilter = document.getElementById('author-filter') as HTMLSelectElement | null;
  const tagFilter = document.getElementById('tag-filter') as HTMLSelectElement | null;
  const mediaFilter = document.getElementById('media-filter') as HTMLSelectElement | null;
  const paginationInfo = document.getElementById('pagination-info');
  const firstPageBtn = document.getElementById('first-page-btn') as HTMLButtonElement | null;
  const prevPageBtn = document.getElementById('prev-page-btn') as HTMLButtonElement | null;
  const nextPageBtn = document.getElementById('next-page-btn') as HTMLButtonElement | null;
  const lastPageBtn = document.getElementById('last-page-btn') as HTMLButtonElement | null;
  const totalCountDisplay = document.getElementById('total-count-display');
  const imageRows = document.querySelectorAll('.image-row');
  const gridCards = document.querySelectorAll('.grid-image-card');

  let activeView = 'table'; // 'table' or 'grid'
  let currentPage = 1;
  let filteredTableRows: HTMLElement[] = [];
  let filteredGridCards: HTMLElement[] = [];
  let filteredRows: HTMLElement[] = [];

  // Parse rows data
  const rowsData = Array.from(imageRows).map((row) => {
    const el = row as HTMLElement;
    const id = el.getAttribute('data-id');
    const title = (el.querySelector('.image-title')?.textContent || '').toLowerCase();
    const author = (el.dataset.author || '').toLowerCase();
    const authorDisplayName = el.dataset.authorDisplayName || '';
    const authorSearch = (el.dataset.authorSearch || author).toLowerCase();
    const description = (el.querySelector('.image-desc-preview')?.textContent || '').toLowerCase();
    const published = el.getAttribute('data-published') === '1';
    const hasPhoto = el.getAttribute('data-has-photo') === 'true';
    const hasVideo = el.getAttribute('data-has-video') === 'true';
    const tags: string[] = [];
    el.querySelectorAll('.table-tag').forEach(tagEl => {
      tags.push((tagEl.textContent || '').replace(/^#/, '').trim());
    });

    return { el, id, title, author, authorDisplayName, authorSearch, description, published, hasPhoto, hasVideo, tags };
  });

  // Parse grid cards data
  const cardsData = Array.from(gridCards).map((card) => {
    const el = card as HTMLElement;
    const id = el.getAttribute('data-id');
    const rowMatch = rowsData.find(r => r.id === id);
    return {
      el,
      id,
      title: rowMatch?.title || '',
      author: rowMatch?.author || '',
      authorSearch: rowMatch?.authorSearch || '',
      description: rowMatch?.description || '',
      published: rowMatch?.published ?? false,
      hasPhoto: rowMatch?.hasPhoto ?? false,
      hasVideo: rowMatch?.hasVideo ?? false,
      tags: rowMatch?.tags || []
    };
  });

  // Populate filter selectors
  if (authorFilter && tagFilter) {
    const uniqueAuthors = new Map<string, string>();
    rowsData.forEach((row) => {
      if (row.author) uniqueAuthors.set(row.author, formatAuthorName(row.authorDisplayName, row.author));
    });
    const uniqueTags = Array.from(new Set(rowsData.flatMap(r => r.tags).filter(Boolean))).sort();

    [...uniqueAuthors.entries()].sort((a, b) => a[1].localeCompare(b[1])).forEach(([author, label]) => {
      const opt = document.createElement('option');
      opt.value = author;
      opt.textContent = label;
      authorFilter.appendChild(opt);
    });

    uniqueTags.forEach(tag => {
      const opt = document.createElement('option');
      opt.value = tag;
      opt.textContent = `#${tag}`;
      tagFilter.appendChild(opt);
    });
  }

  function applyFilters() {
    // Uncheck checkboxes when filters change to prevent deleting non-visible items
    document.querySelectorAll('.image-select-checkbox').forEach(cb => {
      (cb as HTMLInputElement).checked = false;
    });
    if (selectAllCheckbox) selectAllCheckbox.checked = false;
    updateBulkActionsState();

    const searchVal = (searchInput?.value || '').trim().toLowerCase();
    const authorVal = (authorFilter?.value || '').toLowerCase();
    const tagVal = (tagFilter?.value || '');
    const mediaVal = (mediaFilter?.value || '');

    filteredTableRows = [];
    filteredGridCards = [];

    // Filter table rows
    rowsData.forEach(row => {
      const matchesTab = (activeTab === 'published' && row.published) || (activeTab === 'pending' && !row.published);
      const matchesSearch = !searchVal ||
        row.title.includes(searchVal) ||
        row.authorSearch.includes(searchVal) ||
        row.description.includes(searchVal);
      const matchesAuthor = !authorVal || row.author === authorVal;
      const matchesTag = !tagVal || row.tags.includes(tagVal);

      let matchesMedia = true;
      if (mediaVal === 'photo') {
        matchesMedia = row.hasPhoto;
      } else if (mediaVal === 'video') {
        matchesMedia = row.hasVideo;
      }

      if (matchesSearch && matchesAuthor && matchesTag && matchesTab && matchesMedia) {
        filteredTableRows.push(row.el);
      } else {
        row.el.style.display = 'none';
      }
    });

    // Filter grid cards
    cardsData.forEach(card => {
      const matchesTab = (activeTab === 'published' && card.published) || (activeTab === 'pending' && !card.published);
      const matchesSearch = !searchVal ||
        card.title.includes(searchVal) ||
        card.authorSearch.includes(searchVal) ||
        card.description.includes(searchVal);
      const matchesAuthor = !authorVal || card.author === authorVal;
      const matchesTag = !tagVal || card.tags.includes(tagVal);

      let matchesMedia = true;
      if (mediaVal === 'photo') {
        matchesMedia = card.hasPhoto;
      } else if (mediaVal === 'video') {
        matchesMedia = card.hasVideo;
      }

      if (matchesSearch && matchesAuthor && matchesTag && matchesTab && matchesMedia) {
        filteredGridCards.push(card.el);
      } else {
        card.el.style.display = 'none';
      }
    });

    // Set filteredRows based on activeView
    filteredRows = activeView === 'table' ? filteredTableRows : filteredGridCards;

    // Reset pagination to first page after filtering
    currentPage = 1;
    updatePagination();
  }

  function updatePagination() {
    filteredRows = activeView === 'table' ? filteredTableRows : filteredGridCards;
    const totalItems = filteredRows.length;
    const itemsPerPage = activeView === 'grid' ? 25 : 10;
    const totalPages = Math.ceil(totalItems / itemsPerPage) || 1;

    // Bounds check
    if (currentPage < 1) currentPage = 1;
    if (currentPage > totalPages) currentPage = totalPages;

    const startIndex = (currentPage - 1) * itemsPerPage;
    const endIndex = Math.min(startIndex + itemsPerPage, totalItems);

    // Hide all first
    rowsData.forEach(row => {
      row.el.style.display = 'none';
    });
    cardsData.forEach(card => {
      card.el.style.display = 'none';
    });

    // Show current page items
    if (activeView === 'table') {
      for (let i = startIndex; i < endIndex; i++) {
        filteredRows[i].style.display = 'table-row';
      }
    } else {
      for (let i = startIndex; i < endIndex; i++) {
        filteredRows[i].style.display = 'block';
      }
    }

    // Update pagination controls
    if (paginationInfo) {
      if (totalItems > 0) {
        paginationInfo.textContent = `顯示第 ${startIndex + 1}-${endIndex} 筆，共 ${totalItems} 筆`;
      } else {
        paginationInfo.textContent = '查無任何貼文';
      }
    }

    if (totalCountDisplay) {
      totalCountDisplay.textContent = totalItems.toString();
    }

    if (firstPageBtn) firstPageBtn.disabled = currentPage === 1;
    if (prevPageBtn) prevPageBtn.disabled = currentPage === 1;
    if (nextPageBtn) nextPageBtn.disabled = currentPage === totalPages;
    if (lastPageBtn) lastPageBtn.disabled = currentPage === totalPages;
  }

  // Event Listeners
  searchInput?.addEventListener('input', applyFilters);
  authorFilter?.addEventListener('change', applyFilters);
  tagFilter?.addEventListener('change', applyFilters);
  mediaFilter?.addEventListener('change', applyFilters);

  firstPageBtn?.addEventListener('click', () => {
    if (currentPage > 1) {
      currentPage = 1;
      updatePagination();
    }
  });

  prevPageBtn?.addEventListener('click', () => {
    if (currentPage > 1) {
      currentPage--;
      updatePagination();
    }
  });

  nextPageBtn?.addEventListener('click', () => {
    const itemsPerPage = activeView === 'grid' ? 25 : 10;
    const totalPages = Math.ceil(filteredRows.length / itemsPerPage);
    if (currentPage < totalPages) {
      currentPage++;
      updatePagination();
    }
  });

  lastPageBtn?.addEventListener('click', () => {
    const itemsPerPage = activeView === 'grid' ? 25 : 10;
    const totalPages = Math.ceil(filteredRows.length / itemsPerPage) || 1;
    if (currentPage < totalPages) {
      currentPage = totalPages;
      updatePagination();
    }
  });

  // View toggle event listeners
  const viewToggleTable = document.getElementById('view-toggle-table');
  const viewToggleGrid = document.getElementById('view-toggle-grid');
  const tableViewEl = document.querySelector('.view-mode-table') as HTMLElement | null;
  const gridViewEl = document.querySelector('.view-mode-grid') as HTMLElement | null;

  function switchView(view: 'table' | 'grid') {
    if (activeView === view) return;
    activeView = view;

    // Uncheck everything to prevent hidden selections
    document.querySelectorAll('.image-select-checkbox').forEach(cb => {
      (cb as HTMLInputElement).checked = false;
    });
    if (selectAllCheckbox) selectAllCheckbox.checked = false;
    updateBulkActionsState();

    if (view === 'table') {
      viewToggleTable?.classList.add('active');
      viewToggleGrid?.classList.remove('active');
      if (tableViewEl) tableViewEl.style.display = 'block';
      if (gridViewEl) gridViewEl.style.display = 'none';
    } else {
      viewToggleGrid?.classList.add('active');
      viewToggleTable?.classList.remove('active');
      if (gridViewEl) gridViewEl.style.display = 'block';
      if (tableViewEl) tableViewEl.style.display = 'none';
    }

    currentPage = 1;
    updatePagination();
  }

  viewToggleTable?.addEventListener('click', () => switchView('table'));
  viewToggleGrid?.addEventListener('click', () => switchView('grid'));

  // Attach settings change handlers on page load
  document.querySelectorAll('.toggle-enabled-cb, .toggle-crawlall-cb').forEach(cb => {
    cb.addEventListener('change', handleToggleCrawlSetting);
  });

  // Listen for individual row checkbox changes
  document.addEventListener('change', (e) => {
    const target = e.target as HTMLElement;
    if (target && target.classList.contains('image-select-checkbox')) {
      updateBulkActionsState();
    }
  });

  // Listen for clicks on the elements to toggle checkboxes (Grid card or Table thumbnail)
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;

    // Prevent toggling when clicking on interactive elements
    if (
      target.tagName === 'INPUT' || 
      target.tagName === 'BUTTON' || 
      target.closest('button') || 
      target.closest('a')
    ) {
      return;
    }

    // Case 1: Grid card click
    const gridCard = target.closest('.grid-image-card') as HTMLElement | null;
    if (gridCard) {
      const cb = gridCard.querySelector('.image-select-checkbox') as HTMLInputElement | null;
      if (cb) {
        cb.checked = !cb.checked;
        cb.dispatchEvent(new Event('change', { bubbles: true }));
      }
      return;
    }

    // Case 2: Table thumbnail click
    const thumbContainer = target.closest('.thumb-container') as HTMLElement | null;
    if (thumbContainer) {
      const row = thumbContainer.closest('.image-row') as HTMLElement | null;
      if (row) {
        const cb = row.querySelector('.image-select-checkbox') as HTMLInputElement | null;
        if (cb) {
          cb.checked = !cb.checked;
          cb.dispatchEvent(new Event('change', { bubbles: true }));
        }
      }
      return;
    }
  });

  // Select all checkbox handler
  selectAllCheckbox?.addEventListener('change', () => {
    const isChecked = selectAllCheckbox.checked;
    
    // Check/uncheck only currently filtered/visible rows
    filteredRows.forEach(rowEl => {
      const cb = rowEl.querySelector('.image-select-checkbox') as HTMLInputElement | null;
      if (cb) {
        cb.checked = isChecked;
      }
    });

    updateBulkActionsState();
  });

  autoTagBtn?.addEventListener('click', async () => {
    const confirmed = confirm('確定要重新掃描所有圖片嗎？\n只會新增缺少的 Auto-tags，不會移除人工標籤。');
    if (!confirmed) return;

    autoTagBtn.disabled = true;
    let cursor = 0;
    let scanned = 0;
    let added = 0;
    let total = 0;

    updateOperationProgress(
      autoTagProgress,
      autoTagProgressBar,
      autoTagProgressText,
      0,
      1,
      '準備掃描...'
    );

    try {
      while (true) {
        const response = await fetch('/admin/api/auto-tag', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ cursor, limit: 50 })
        });
        const data = await response.json();
        if (!response.ok) throw new Error(data.error || 'Auto-tag 執行失敗');

        scanned += Number(data.scanned || 0);
        added += Number(data.added || 0);
        total = Number(data.total || total);
        updateOperationProgress(
          autoTagProgress,
          autoTagProgressBar,
          autoTagProgressText,
          scanned,
          total,
          `已掃描 ${scanned} / ${total}，已新增 ${added} 個標籤關聯`
        );

        if (data.done) break;
        const nextCursor = Number(data.nextCursor);
        if (!Number.isFinite(nextCursor) || nextCursor <= cursor) {
          throw new Error('Auto-tag cursor 沒有前進');
        }
        cursor = nextCursor;
      }

      if (autoTagProgressText) {
        autoTagProgressText.textContent = `完成：已掃描 ${scanned} 張，新增 ${added} 個標籤關聯`;
      }
      alert(`Auto-tag 完成！\n已掃描 ${scanned} 張圖片，新增 ${added} 個標籤關聯。`);
      window.location.reload();
    } catch (err: any) {
      console.error('Error running auto-tag backfill:', err);
      if (autoTagProgressText) {
        autoTagProgressText.textContent = `失敗：${err.message}`;
      }
      alert(`Auto-tag 執行失敗：${err.message}`);
      autoTagBtn.disabled = false;
    }
  });

  // Bulk delete action handler
  bulkDeleteBtn?.addEventListener('click', async () => {
    const checkedCheckboxes = document.querySelectorAll('.image-select-checkbox:checked');
    const ids = Array.from(checkedCheckboxes).map(cb => parseInt(cb.getAttribute('data-id') || '', 10)).filter(id => !isNaN(id));

    if (ids.length === 0) return;

    const confirmed = confirm(`確定要刪除這 ${ids.length} 張照片嗎？\n這會自資料庫中移除，並同步刪除 R2 儲存的實體檔案，此操作無法復原！`);
    if (!confirmed) return;

    bulkDeleteBtn.disabled = true;
    bulkDeleteBtn.textContent = '刪除中...';
    let deletedCount = 0;
    updateOperationProgress(
      bulkDeleteProgress,
      bulkDeleteProgressBar,
      bulkDeleteProgressText,
      0,
      ids.length,
      `已刪除 0 / ${ids.length}`
    );

    try {
      deletedCount = await runSequentialBatches(ids, 50, async (batch) => {
        const response = await fetch('/api/images/bulk-delete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ids: batch })
        });
        const data = await response.json();
        if (!response.ok || !data.success) {
          throw new Error(data.error || '刪除失敗');
        }
        return Number(data.count || batch.length);
      }, (completed) => {
        deletedCount = completed;
        updateOperationProgress(
          bulkDeleteProgress,
          bulkDeleteProgressBar,
          bulkDeleteProgressText,
          deletedCount,
          ids.length,
          `已刪除 ${deletedCount} / ${ids.length}`
        );
      });

      alert(`成功刪除 ${deletedCount} 筆照片！`);
      window.location.reload();
    } catch (err: any) {
      console.error('Error in bulk delete:', err);
      if (bulkDeleteProgressText) {
        bulkDeleteProgressText.textContent = `失敗：已刪除 ${deletedCount} / ${ids.length}。${err.message}`;
      }
      alert(`批次刪除中斷。\n已刪除 ${deletedCount} / ${ids.length} 筆。\n${err.message}`);
      window.location.reload();
    }
  });

  // =========== Tab switching listeners ===========
  function switchTab(newTab: 'published' | 'pending') {
    if (activeTab === newTab) return;
    activeTab = newTab;

    if (tabPublished && tabPending) {
      if (activeTab === 'published') {
        tabPublished.classList.add('active');
        (tabPublished as HTMLElement).style.color = 'var(--text-primary)';
        (tabPublished as HTMLElement).style.borderBottom = '2px solid var(--text-primary)';
        (tabPublished as HTMLElement).style.fontWeight = '600';

        tabPending.classList.remove('active');
        (tabPending as HTMLElement).style.color = 'var(--text-secondary)';
        (tabPending as HTMLElement).style.borderBottom = '2px solid transparent';
        (tabPending as HTMLElement).style.fontWeight = '500';
      } else {
        tabPending.classList.add('active');
        (tabPending as HTMLElement).style.color = 'var(--text-primary)';
        (tabPending as HTMLElement).style.borderBottom = '2px solid var(--text-primary)';
        (tabPending as HTMLElement).style.fontWeight = '600';

        tabPublished.classList.remove('active');
        (tabPublished as HTMLElement).style.color = 'var(--text-secondary)';
        (tabPublished as HTMLElement).style.borderBottom = '2px solid transparent';
        (tabPublished as HTMLElement).style.fontWeight = '500';
      }
    }

    applyFilters();
  }

  tabPublished?.addEventListener('click', () => switchTab('published'));
  tabPending?.addEventListener('click', () => switchTab('pending'));

  // =========== Approve button listener ===========
  document.querySelectorAll('.approve-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const imgId = btn.getAttribute('data-id');
      if (!imgId) return;

      (btn as HTMLButtonElement).disabled = true;
      btn.textContent = '核准中...';

      try {
        const response = await fetch('/api/admin/approve', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: imgId })
        });

        const data = await response.json();

        if (response.ok && data.success) {
          window.location.reload();
        } else {
          alert(`核准失敗：${data.error || '未知錯誤'}`);
          (btn as HTMLButtonElement).disabled = false;
          btn.textContent = '核准';
        }
      } catch (err) {
        console.error(err);
        alert('核准失敗，伺服器發生錯誤。');
        (btn as HTMLButtonElement).disabled = false;
        btn.textContent = '核准';
      }
    });
  });


  // Initialize
  applyFilters();
</script>
