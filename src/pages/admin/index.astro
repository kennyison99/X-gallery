---
import { env } from 'cloudflare:workers';
import BaseLayout from '../../layouts/BaseLayout.astro';

if (!env || !env.DB) {
  return new Response('D1 DB binding not configured. Please bind your database in wrangler.jsonc.', { status: 500 });
}

// 1. Fetch all existing tags for reusable selection
let allTags = [];
try {
  const tagsQuery = await env.DB.prepare('SELECT * FROM tags ORDER BY name ASC').all();
  allTags = tagsQuery.results || [];
} catch (err) {
  console.error('Error fetching tags for admin:', err);
}

// 2. Fetch all images/posts for management list
let images = [];
try {
  const query = `
    SELECT i.*, group_concat(t.name) as tags_list
    FROM images i
    LEFT JOIN image_tags it ON i.id = it.image_id
    LEFT JOIN tags t ON it.tag_id = t.id
    GROUP BY i.id
    ORDER BY i.created_at DESC
  `;
  const { results } = await env.DB.prepare(query).all();
  images = results || [];
} catch (err) {
  console.error('Error fetching images for admin:', err);
}

// 3. Fetch crawl accounts
let crawlAccounts = [];
try {
  const { results } = await env.DB.prepare('SELECT * FROM crawl_accounts ORDER BY created_at DESC').all();
  crawlAccounts = results || [];
} catch (err) {
  console.error('Error fetching crawl accounts:', err);
}

const formattedImages = images.map((img: any) => ({
  ...img,
  tags: img.tags_list ? img.tags_list.split(',') : []
}));
---

<BaseLayout title="CMS 後台管理 - Twitter 照片牆">
  <div class="admin-container">
    <div class="admin-header">
      <h1>CMS 管理後台</h1>
      <p>上傳多張相片作為單一卡片貼文到 R2，並管理所有照片與標籤資料。</p>
    </div>

    <div class="admin-grid">
      <!-- Upload Panel -->
      <section class="admin-panel upload-panel">
        <h2 id="form-title-text">發佈相片貼文</h2>
        <form id="upload-form" class="admin-form">
          <div class="form-group">
            <label for="image-file">選擇照片 (支援多選) <span class="required" id="file-required-star">*</span></label>
            <div class="file-dropzone">
              <input type="file" id="image-file" name="file" accept="image/*" multiple required />
              <div class="dropzone-text">
                <span class="upload-icon">📁</span>
                <span class="upload-prompt">點擊選擇照片 (可選多張)</span>
                <span class="file-name-display">尚未選擇任何檔案</span>
              </div>
            </div>
            
            <!-- Image Previews -->
            <div id="image-preview-container" style="display: none; margin-top: 0.75rem; border: 1px solid var(--border-color); border-radius: 6px; padding: 0.6rem; background-color: var(--bg-secondary);">
              <div id="existing-images-preview" class="preview-section" style="display: none; margin-bottom: 0.5rem;">
                <span class="preview-label" style="font-size: 0.8rem; font-weight: 500; display: block; margin-bottom: 0.25rem; color: var(--text-secondary);">目前相片：</span>
                <div class="preview-grid" id="existing-images-grid" style="display: flex; gap: 0.4rem; flex-wrap: wrap;"></div>
              </div>
              <div id="new-images-preview" class="preview-section" style="display: none;">
                <span class="preview-label" style="font-size: 0.8rem; font-weight: 500; display: block; margin-bottom: 0.25rem; color: var(--text-secondary);">即將上傳之新相片：</span>
                <div class="preview-grid" id="new-images-grid" style="display: flex; gap: 0.4rem; flex-wrap: wrap;"></div>
              </div>
            </div>
          </div>

          <div class="form-group">
            <label for="image-title">貼文標題</label>
            <input type="text" id="image-title" name="title" placeholder="例如：推文寫真集 #1" />
          </div>

          <div class="form-group">
            <label for="image-description">感想 / 內文</label>
            <textarea id="image-description" name="description" rows="3" placeholder="寫點關於這組照片的感想或推文內容..."></textarea>
          </div>

          <div class="form-group">
            <label for="image-author">作者 (Twitter 帳號) <span class="required">*</span></label>
            <input type="text" id="image-author" name="author" value="foglantau" placeholder="例如：foglantau" required />
          </div>

          <div class="form-group">
            <label for="image-author-url">作者 Twitter 連結</label>
            <input type="url" id="image-author-url" name="author_url" value="https://x.com/foglantau" placeholder="https://x.com/username" />
          </div>

          <div class="form-group">
            <label for="image-post-url">原推文連結 (post_url)</label>
            <input type="url" id="image-post-url" name="post_url" placeholder="https://x.com/username/status/123456789" />
          </div>

          <!-- Reusable Tags Selection -->
          <div class="form-group">
            <label>選擇已有標籤</label>
            <div class="existing-tags-wrapper">
              {allTags.length > 0 ? (
                allTags.map((tag: any) => (
                  <label class="tag-checkbox-label">
                    <input type="checkbox" name="existing_tags" value={tag.name} />
                    <span>#{tag.name}</span>
                  </label>
                ))
              ) : (
                <p class="empty-text">尚無已有標籤</p>
              )}
            </div>
          </div>

          <div class="form-group">
            <label for="new-tags">新增其他標籤 (以逗號或空格分隔)</label>
            <input type="text" id="new-tags" name="new_tags" placeholder="例如：絲襪, 日常" />
            <p class="form-help">新標籤會自動去重並加入資料庫供下次使用。</p>
          </div>

          <div class="form-actions" style="display: flex; gap: 0.5rem; width: 100%;">
            <button type="submit" class="btn btn-primary btn-submit" style="flex: 1;">
              <span class="btn-text">確認上傳</span>
              <span class="loader-spinner" style="display: none;"></span>
            </button>
            <button type="button" id="cancel-edit-btn" class="btn" style="display: none; flex: 1;">
              取消編輯
            </button>
          </div>
          <div id="upload-message" class="form-message"></div>
        </form>
      </section>

      <!-- Manage List Panel -->
      <section class="admin-panel list-panel">
        <h2>照片貼文列表 (<span id="total-count-display">{formattedImages.length}</span>)</h2>
        
        <!-- Search and Filter Bar -->
        <div class="list-filters" style="display: flex; gap: 0.5rem; margin-bottom: 1rem; flex-wrap: wrap;">
          <input type="text" id="search-input" placeholder="搜尋標題、作者或內文..." style="flex: 2; min-width: 180px; padding: 0.5rem 0.8rem; border-radius: 6px; border: 1px solid var(--border-color); background-color: var(--bg-secondary); color: var(--text-primary); font-size: 0.85rem; outline: none; transition: border-color var(--transition-speed) ease;" onfocus="this.style.borderColor='var(--text-primary)'" onblur="this.style.borderColor='var(--border-color)'" />
          <select id="author-filter" style="flex: 1; min-width: 120px; padding: 0.5rem 0.8rem; border-radius: 6px; border: 1px solid var(--border-color); background-color: var(--bg-secondary); color: var(--text-primary); font-size: 0.85rem; cursor: pointer; outline: none; transition: border-color var(--transition-speed) ease;" onfocus="this.style.borderColor='var(--text-primary)'" onblur="this.style.borderColor='var(--border-color)'">
            <option value="">所有作者</option>
          </select>
          <select id="tag-filter" style="flex: 1; min-width: 120px; padding: 0.5rem 0.8rem; border-radius: 6px; border: 1px solid var(--border-color); background-color: var(--bg-secondary); color: var(--text-primary); font-size: 0.85rem; cursor: pointer; outline: none; transition: border-color var(--transition-speed) ease;" onfocus="this.style.borderColor='var(--text-primary)'" onblur="this.style.borderColor='var(--border-color)'">
            <option value="">所有標籤</option>
          </select>
        </div>

        <!-- Bulk Actions Bar -->
        <div id="bulk-actions-bar" class="bulk-actions" style="display: none; align-items: center; justify-content: space-between; gap: 0.5rem; margin-bottom: 1rem; padding: 0.6rem 0.8rem; border-radius: 6px; border: 1px solid var(--border-color); background-color: var(--bg-secondary);">
          <span id="selected-count-display" style="font-size: 0.85rem; color: var(--text-secondary); font-weight: 500;">已選擇 0 筆照片</span>
          <button id="bulk-delete-btn" class="btn btn-danger" style="font-size: 0.8rem; padding: 0.3rem 0.75rem;">
            刪除所選
          </button>
        </div>

        <div class="table-wrapper">
          {formattedImages.length > 0 ? (
            <table class="admin-table">
              <thead>
                <tr>
                  <th style="width: 40px; text-align: center;"><input type="checkbox" id="select-all-checkbox" style="cursor: pointer;" /></th>
                  <th>預覽</th>
                  <th>貼文資訊</th>
                  <th>標籤</th>
                  <th style="text-align: right;">操作</th>
                </tr>
              </thead>
              <tbody>
                {formattedImages.map((image) => {
                  const keys = image.r2_keys.split(',');
                  const firstKey = keys[0] || '';
                  const totalCount = keys.length;
                  return (
                    <tr class="image-row" data-id={image.id}>
                      <td style="text-align: center; vertical-align: middle;">
                        <input type="checkbox" class="image-select-checkbox" data-id={image.id} style="cursor: pointer;" />
                      </td>
                      <td>
                        <div class="thumb-container" style="position: relative; width: 48px; height: 48px;">
                          <img 
                            src={`/api/r2/${encodeURIComponent(firstKey)}`} 
                            alt={image.title} 
                            class="admin-thumb" 
                          />
                          {totalCount > 1 && (
                            <span class="thumb-count-badge">+{totalCount - 1}</span>
                          )}
                        </div>
                      </td>
                      <td>
                        <div class="image-title">{image.title || '無標題'}</div>
                        <div class="image-author">@{image.author}</div>
                        {image.description && <div class="image-desc-preview" title={image.description}>{image.description}</div>}
                        <div class="image-date">{new Date(image.created_at).toLocaleDateString()}</div>
                      </td>
                      <td>
                        <div class="table-tags">
                          {image.tags.map((tag: string) => (
                            <span class="table-tag">#{tag}</span>
                          ))}
                        </div>
                      </td>
                      <td style="text-align: right;">
                        <div class="table-actions" style="display: flex; gap: 0.3rem; justify-content: flex-end;">
                          <button 
                            class="btn edit-btn" 
                            style="font-size: 0.8rem; padding: 0.3rem 0.6rem;"
                            data-id={image.id}
                            data-title={image.title}
                            data-description={image.description || ''}
                            data-author={image.author}
                            data-author-url={image.author_url || ''}
                            data-post-url={image.post_url || ''}
                            data-tags={image.tags.join(',')}
                            data-keys={image.r2_keys}
                          >
                            編輯
                          </button>
                          <button class="btn btn-danger delete-btn" style="font-size: 0.8rem; padding: 0.3rem 0.6rem;" data-id={image.id}>
                            刪除
                          </button>
                        </div>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          ) : (
            <div class="empty-table-state">
              <p>資料庫目前無照片，請從左側上傳。</p>
            </div>
          )}
        </div>

        <!-- Pagination Controls -->
        <div class="pagination-controls" id="pagination-controls" style="display: flex; justify-content: space-between; align-items: center; margin-top: 1rem; font-size: 0.85rem; color: var(--text-secondary); border-top: 1px solid var(--border-color); padding-top: 0.75rem;">
          <span class="pagination-info" id="pagination-info">顯示第 1-10 筆，共 0 筆</span>
          <div style="display: flex; gap: 0.4rem;">
            <button type="button" id="prev-page-btn" class="btn" style="padding: 0.25rem 0.6rem; font-size: 0.8rem;">上一頁</button>
            <button type="button" id="next-page-btn" class="btn" style="padding: 0.25rem 0.6rem; font-size: 0.8rem;">下一頁</button>
          </div>
        </div>
      </section>

      <!-- Crawl Accounts Panel -->
      <section class="admin-panel crawl-panel" style="grid-column: 1 / -1;">
        <h2>自動爬取帳號管理</h2>
        <p class="crawl-desc">新增 Twitter/X 帳號後，GitHub Actions 將每日自動爬取該帳號的最新圖片並上傳。</p>
        
        <div class="crawl-add-form">
          <input type="text" id="crawl-username" placeholder="輸入 Twitter 帳號（例如 foglantau）" />
          <button type="button" id="add-crawl-btn" class="btn btn-primary" style="white-space: nowrap;">新增帳號</button>
        </div>
        <div id="crawl-message" class="form-message" style="margin-top: 0.5rem;"></div>

        <div class="crawl-accounts-list" id="crawl-accounts-list">
          {crawlAccounts.length > 0 ? (
            crawlAccounts.map((account: any) => (
              <div class="crawl-account-item" data-username={account.username}>
                <div class="crawl-account-info">
                  <span class="crawl-account-name">@{account.username}</span>
                  <a href={`https://x.com/${account.username}`} target="_blank" rel="noopener noreferrer" class="crawl-account-link" title="前往 Twitter">↗</a>
                  {account.last_crawled_at && (
                    <span class="crawl-last-time">上次爬取：{new Date(account.last_crawled_at).toLocaleString('zh-TW')}</span>
                  )}
                </div>
                <div class="crawl-account-settings" style="display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;">
                  <label style="display: flex; align-items: center; gap: 0.25rem; font-size: 0.8rem; cursor: pointer; color: var(--text-secondary);">
                    <input type="checkbox" class="toggle-enabled-cb" data-username={account.username} checked={account.enabled === 1} />
                    <span>啟用自動爬取</span>
                  </label>
                  <label style="display: flex; align-items: center; gap: 0.25rem; font-size: 0.8rem; cursor: pointer; color: var(--text-secondary);">
                    <input type="checkbox" class="toggle-crawlall-cb" data-username={account.username} checked={account.crawl_all === 1} />
                    <span>爬取全部歷史圖片</span>
                  </label>
                  <button class="btn btn-danger remove-crawl-btn" data-username={account.username} style="font-size: 0.8rem; padding: 0.25rem 0.5rem; margin-left: 0.5rem;">移除</button>
                </div>
              </div>
            ))
          ) : (
            <p class="empty-text" id="crawl-empty-text">尚未新增任何爬取帳號。</p>
          )}
        </div>
      </section>
    </div>
  </div>
</BaseLayout>

<script>
  // Bulk action UI bindings
  const selectAllCheckbox = document.getElementById('select-all-checkbox') as HTMLInputElement | null;
  const bulkActionsBar = document.getElementById('bulk-actions-bar');
  const selectedCountDisplay = document.getElementById('selected-count-display');
  const bulkDeleteBtn = document.getElementById('bulk-delete-btn') as HTMLButtonElement | null;

  function updateBulkActionsState() {
    const checkedCheckboxes = document.querySelectorAll('.image-select-checkbox:checked');
    const checkedCount = checkedCheckboxes.length;

    if (selectedCountDisplay) {
      selectedCountDisplay.textContent = `已選擇 ${checkedCount} 筆照片`;
    }

    if (bulkActionsBar) {
      bulkActionsBar.style.display = checkedCount > 0 ? 'flex' : 'none';
    }

    if (selectAllCheckbox) {
      const visibleCheckboxes = (typeof filteredRows !== 'undefined' && filteredRows) ? filteredRows.map(row => row.querySelector('.image-select-checkbox') as HTMLInputElement).filter(Boolean) : [];
      const checkedVisibleCount = visibleCheckboxes.filter(cb => cb.checked).length;
      selectAllCheckbox.checked = visibleCheckboxes.length > 0 && checkedVisibleCount === visibleCheckboxes.length;
    }
  }

  // UI interactions for file input
  const fileInput = document.getElementById('image-file') as HTMLInputElement | null;
  const fileNameDisplay = document.querySelector('.file-name-display');
  const uploadPrompt = document.querySelector('.upload-prompt');
  const fileRequiredStar = document.getElementById('file-required-star');
  const formTitleText = document.getElementById('form-title-text');
  const cancelBtn = document.getElementById('cancel-edit-btn') as HTMLButtonElement | null;
  const newTagsInput = document.getElementById('new-tags') as HTMLInputElement | null;

  const titleInput = document.getElementById('image-title') as HTMLInputElement | null;
  const descInput = document.getElementById('image-description') as HTMLTextAreaElement | null;
  const authorInput = document.getElementById('image-author') as HTMLInputElement | null;
  const authorUrlInput = document.getElementById('image-author-url') as HTMLInputElement | null;
  const postUrlInput = document.getElementById('image-post-url') as HTMLInputElement | null;

  // Previews elements
  const previewContainer = document.getElementById('image-preview-container');
  const existingPreviewSection = document.getElementById('existing-images-preview');
  const existingGrid = document.getElementById('existing-images-grid');
  const newPreviewSection = document.getElementById('new-images-preview');
  const newGrid = document.getElementById('new-images-grid');

  let isEditMode = false;
  let editingId: string | null = null;

  // Keep track of files and existing keys
  let remainingExistingKeys: string[] = [];
  let selectedNewFiles: File[] = [];

  // Render new selected files preview
  function renderNewFilesPreview() {
    if (!newGrid || !newPreviewSection || !previewContainer) return;
    newGrid.innerHTML = '';
    
    if (selectedNewFiles.length > 0) {
      newPreviewSection.style.display = 'block';
      previewContainer.style.display = 'block';
      
      selectedNewFiles.forEach((file, index) => {
        const itemWrapper = document.createElement('div');
        itemWrapper.style.position = 'relative';
        itemWrapper.style.width = '60px';
        itemWrapper.style.height = '60px';
        
        const img = document.createElement('img');
        img.style.width = '60px';
        img.style.height = '60px';
        img.style.objectFit = 'cover';
        img.style.borderRadius = '4px';
        img.style.border = '1px solid var(--border-color)';
        
        const removeBtn = document.createElement('button');
        removeBtn.type = 'button';
        removeBtn.innerHTML = '×';
        removeBtn.style.position = 'absolute';
        removeBtn.style.top = '-4px';
        removeBtn.style.right = '-4px';
        removeBtn.style.background = 'var(--heart-color)';
        removeBtn.style.color = 'white';
        removeBtn.style.border = 'none';
        removeBtn.style.borderRadius = '50%';
        removeBtn.style.width = '18px';
        removeBtn.style.height = '18px';
        removeBtn.style.fontSize = '10px';
        removeBtn.style.fontWeight = 'bold';
        removeBtn.style.cursor = 'pointer';
        removeBtn.style.display = 'flex';
        removeBtn.style.alignItems = 'center';
        removeBtn.style.justifyContent = 'center';
        removeBtn.style.padding = '0';
        
        removeBtn.addEventListener('click', () => {
          selectedNewFiles.splice(index, 1);
          renderNewFilesPreview();
          updateFileInputDisplay();
        });
        
        const reader = new FileReader();
        reader.onload = (e) => {
          img.src = e.target?.result as string;
        };
        reader.readAsDataURL(file);
        
        itemWrapper.appendChild(img);
        itemWrapper.appendChild(removeBtn);
        newGrid.appendChild(itemWrapper);
      });
    } else {
      newPreviewSection.style.display = 'none';
      if (remainingExistingKeys.length === 0) {
        previewContainer.style.display = 'none';
      }
    }
  }

  // Render existing images preview
  function renderExistingImagesPreview() {
    if (!existingGrid || !existingPreviewSection || !previewContainer) return;
    existingGrid.innerHTML = '';
    
    if (remainingExistingKeys.length > 0) {
      existingPreviewSection.style.display = 'block';
      previewContainer.style.display = 'block';
      
      remainingExistingKeys.forEach((key, index) => {
        const itemWrapper = document.createElement('div');
        itemWrapper.style.position = 'relative';
        itemWrapper.style.width = '60px';
        itemWrapper.style.height = '60px';
        
        const img = document.createElement('img');
        img.src = `/api/r2/${encodeURIComponent(key)}`;
        img.style.width = '60px';
        img.style.height = '60px';
        img.style.objectFit = 'cover';
        img.style.borderRadius = '4px';
        img.style.border = '1px solid var(--border-color)';
        
        const removeBtn = document.createElement('button');
        removeBtn.type = 'button';
        removeBtn.innerHTML = '×';
        removeBtn.style.position = 'absolute';
        removeBtn.style.top = '-4px';
        removeBtn.style.right = '-4px';
        removeBtn.style.background = 'var(--heart-color)';
        removeBtn.style.color = 'white';
        removeBtn.style.border = 'none';
        removeBtn.style.borderRadius = '50%';
        removeBtn.style.width = '18px';
        removeBtn.style.height = '18px';
        removeBtn.style.fontSize = '10px';
        removeBtn.style.fontWeight = 'bold';
        removeBtn.style.cursor = 'pointer';
        removeBtn.style.display = 'flex';
        removeBtn.style.alignItems = 'center';
        removeBtn.style.justifyContent = 'center';
        removeBtn.style.padding = '0';
        
        removeBtn.addEventListener('click', () => {
          remainingExistingKeys.splice(index, 1);
          renderExistingImagesPreview();
        });
        
        itemWrapper.appendChild(img);
        itemWrapper.appendChild(removeBtn);
        existingGrid.appendChild(itemWrapper);
      });
    } else {
      existingPreviewSection.style.display = 'none';
      if (selectedNewFiles.length === 0) {
        previewContainer.style.display = 'none';
      }
    }
  }

  function updateFileInputDisplay() {
    if (!fileNameDisplay) return;
    const count = selectedNewFiles.length;
    if (count > 0) {
      fileNameDisplay.textContent = `已選取 ${count} 個檔案`;
    } else {
      fileNameDisplay.textContent = '尚未選擇任何檔案';
    }
  }

  if (fileInput) {
    fileInput.addEventListener('change', () => {
      if (fileInput.files) {
        // Accumulate newly selected files
        Array.from(fileInput.files).forEach(file => {
          selectedNewFiles.push(file);
        });
        // Clear file input value so user can select the same file again
        fileInput.value = '';
        updateFileInputDisplay();
        renderNewFilesPreview();
      }
    });
  }

  function resetForm() {
    isEditMode = false;
    editingId = null;
    remainingExistingKeys = [];
    selectedNewFiles = [];
    
    if (uploadForm) uploadForm.reset();
    if (formTitleText) formTitleText.textContent = '發佈相片貼文';
    if (btnText) btnText.textContent = '確認上傳';
    if (cancelBtn) cancelBtn.style.display = 'none';
    if (fileInput) fileInput.required = true;
    if (fileRequiredStar) fileRequiredStar.style.display = 'inline';
    if (uploadPrompt) uploadPrompt.textContent = '點擊選擇照片 (可選多張)';
    if (fileNameDisplay) fileNameDisplay.textContent = '尚未選擇任何檔案';
    
    // Reset previews
    if (existingGrid) existingGrid.innerHTML = '';
    if (existingPreviewSection) existingPreviewSection.style.display = 'none';
    if (newGrid) newGrid.innerHTML = '';
    if (newPreviewSection) newPreviewSection.style.display = 'none';
    if (previewContainer) previewContainer.style.display = 'none';

    if (uploadMessage) {
      uploadMessage.textContent = '';
      uploadMessage.style.display = 'none';
    }
  }

  function enterEditMode(id: string, data: any) {
    isEditMode = true;
    editingId = id;
    selectedNewFiles = [];
    remainingExistingKeys = data.keys.split(',').map((k: string) => k.trim()).filter(Boolean);

    if (formTitleText) formTitleText.textContent = '修改相片貼文';
    if (btnText) btnText.textContent = '確認修改';
    if (cancelBtn) cancelBtn.style.display = 'inline-block';
    if (fileInput) {
      fileInput.required = false;
      fileInput.value = '';
    }
    if (fileRequiredStar) fileRequiredStar.style.display = 'none';
    if (uploadPrompt) uploadPrompt.textContent = '上傳新照片以附加至貼文 (可選多張)';
    if (fileNameDisplay) fileNameDisplay.textContent = '尚未選擇任何檔案';
    
    if (titleInput) titleInput.value = data.title;
    if (descInput) descInput.value = data.description;
    if (authorInput) authorInput.value = data.author;
    if (authorUrlInput) authorUrlInput.value = data.authorUrl;
    if (postUrlInput) postUrlInput.value = data.postUrl;

    // Check tags checkboxes
    document.querySelectorAll('input[name="existing_tags"]').forEach((cb) => {
      (cb as HTMLInputElement).checked = false;
    });

    const tagsArray = data.tags.split(',').map((t: string) => t.trim()).filter(Boolean);
    tagsArray.forEach((tag: string) => {
      const checkbox = document.querySelector(`input[name="existing_tags"][value="${tag}"]`) as HTMLInputElement | null;
      if (checkbox) checkbox.checked = true;
    });

    if (newTagsInput) newTagsInput.value = '';

    // Render previews
    renderExistingImagesPreview();
    renderNewFilesPreview();

    if (uploadMessage) {
      uploadMessage.textContent = '';
      uploadMessage.style.display = 'none';
    }
  }

  if (cancelBtn) {
    cancelBtn.addEventListener('click', resetForm);
  }

  // Hook up Edit buttons
  document.querySelectorAll('.edit-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-id');
      const title = btn.getAttribute('data-title') || '';
      const description = btn.getAttribute('data-description') || '';
      const author = btn.getAttribute('data-author') || '';
      const authorUrl = btn.getAttribute('data-author-url') || '';
      const postUrl = btn.getAttribute('data-post-url') || '';
      const tags = btn.getAttribute('data-tags') || '';
      const keys = btn.getAttribute('data-keys') || '';
      
      if (id) {
        enterEditMode(id, { title, description, author, authorUrl, postUrl, tags, keys });
        if (uploadForm) {
          uploadForm.scrollIntoView({ behavior: 'smooth' });
        }
      }
    });
  });

  // Handle Form Upload / Modify
  const uploadForm = document.getElementById('upload-form') as HTMLFormElement | null;
  const submitBtn = document.querySelector('.btn-submit') as HTMLButtonElement | null;
  const btnText = document.querySelector('.btn-text');
  const loaderSpinner = document.querySelector('.loader-spinner') as HTMLElement | null;
  const uploadMessage = document.getElementById('upload-message');

  if (uploadForm && submitBtn && btnText && loaderSpinner && uploadMessage) {
    uploadForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Check if we have at least one image in total
      const totalImages = (isEditMode ? remainingExistingKeys.length : 0) + selectedNewFiles.length;
      if (totalImages === 0) {
        uploadMessage.textContent = '錯誤：貼文必須至少包含一張照片。';
        uploadMessage.className = 'form-message error';
        uploadMessage.style.display = 'block';
        return;
      }
      
      // Update loading UI
      submitBtn.disabled = true;
      btnText.textContent = isEditMode ? '正在修改中...' : '正在上傳中...';
      if (loaderSpinner) loaderSpinner.style.display = 'inline-block';
      uploadMessage.textContent = '';
      uploadMessage.className = 'form-message';
      uploadMessage.style.display = 'none';

      // 1. Prepare FormData
      const formData = new FormData();
      
      // Add manual selected files
      selectedNewFiles.forEach(file => {
        formData.append('file', file);
      });

      // Add existing keys to keep if in edit mode
      if (isEditMode) {
        formData.append('existing_keys', remainingExistingKeys.join(','));
      }

      formData.append('title', titleInput?.value || '');
      formData.append('description', descInput?.value || '');
      formData.append('author', authorInput?.value || '');
      formData.append('author_url', authorUrlInput?.value || '');
      formData.append('post_url', postUrlInput?.value || '');

      // Combine existing tags and new tags
      const checkedTags: string[] = [];
      document.querySelectorAll('input[name="existing_tags"]:checked').forEach((checkbox) => {
        checkedTags.push((checkbox as HTMLInputElement).value);
      });

      const newTagsRaw = newTagsInput?.value || '';

      const tagsCombined = [
        ...checkedTags,
        ...newTagsRaw.split(/[\s,]+/).map(t => t.trim().replace(/^#/, '')).filter(t => t.length > 0)
      ].join(',');

      formData.append('tags', tagsCombined);

      try {
        const url = isEditMode ? `/api/images/${editingId}` : '/api/images';
        const method = isEditMode ? 'PUT' : 'POST';

        const response = await fetch(url, {
          method: method,
          body: formData
        });

        const data = await response.json();
        
        if (response.ok && data.success) {
          uploadMessage.textContent = isEditMode ? '貼文修改成功！正在重新整理頁面...' : '貼文上傳成功！正在重新整理頁面...';
          uploadMessage.className = 'form-message success';
          uploadMessage.style.display = 'block';
          resetForm();
          
          setTimeout(() => {
            window.location.reload();
          }, 1500);
        } else {
          uploadMessage.textContent = `${isEditMode ? '修改' : '上傳'}失敗：${data.error || '未知錯誤'}`;
          uploadMessage.className = 'form-message error';
          uploadMessage.style.display = 'block';
          submitBtn.disabled = false;
          btnText.textContent = isEditMode ? '確認修改' : '確認上傳';
          if (loaderSpinner) loaderSpinner.style.display = 'none';
        }
      } catch (err) {
        console.error(err);
        uploadMessage.textContent = '網路或伺服器錯誤，請稍後再試。';
        uploadMessage.className = 'form-message error';
        uploadMessage.style.display = 'block';
        submitBtn.disabled = false;
        btnText.textContent = isEditMode ? '確認修改' : '確認上傳';
        if (loaderSpinner) loaderSpinner.style.display = 'none';
      }
    });
  }

  // Handle Deletion
  document.querySelectorAll('.delete-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const imgId = btn.getAttribute('data-id');
      if (!imgId) return;

      if (!confirm('你確定要刪除這張照片貼文嗎？此操作將會從資料庫與 Cloudflare R2 中永久刪除該貼文的所有照片！')) {
        return;
      }

      (btn as HTMLButtonElement).disabled = true;
      btn.textContent = '刪除中...';

      try {
        const response = await fetch(`/api/images/${imgId}`, {
          method: 'DELETE'
        });

        const data = await response.json();

        if (response.ok && data.success) {
          const row = document.querySelector(`.image-row[data-id="${imgId}"]`);
          if (row) {
            row.remove();
          }
          const remainingRows = document.querySelectorAll('.image-row');
          if (remainingRows.length === 0) {
            window.location.reload();
          }
        } else {
          alert(`刪除失敗：${data.error || '未知錯誤'}`);
          (btn as HTMLButtonElement).disabled = false;
          btn.textContent = '刪除';
        }
      } catch (err) {
        console.error(err);
        alert('刪除失敗，伺服器發生錯誤。');
        (btn as HTMLButtonElement).disabled = false;
        btn.textContent = '刪除';
      }
    });
  });

  // =========== Crawl Accounts Management ===========
  const crawlUsernameInput = document.getElementById('crawl-username') as HTMLInputElement | null;
  const addCrawlBtn = document.getElementById('add-crawl-btn') as HTMLButtonElement | null;
  const crawlMessage = document.getElementById('crawl-message') as HTMLElement | null;
  const crawlAccountsList = document.getElementById('crawl-accounts-list');
  const crawlEmptyText = document.getElementById('crawl-empty-text');

  function showCrawlMessage(text: string, type: 'success' | 'error') {
    if (!crawlMessage) return;
    crawlMessage.textContent = text;
    crawlMessage.className = `form-message ${type}`;
    crawlMessage.style.display = 'block';
    setTimeout(() => {
      crawlMessage.style.display = 'none';
    }, 3000);
  }

  if (addCrawlBtn && crawlUsernameInput) {
    addCrawlBtn.addEventListener('click', async () => {
      const username = crawlUsernameInput.value.trim().replace(/^@/, '');
      if (!username) {
        showCrawlMessage('請輸入帳號名稱', 'error');
        return;
      }

      addCrawlBtn.disabled = true;
      addCrawlBtn.textContent = '新增中...';

      try {
        const res = await fetch('/api/crawl-accounts', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username })
        });
        const data = await res.json();

        if (res.ok && data.success) {
          showCrawlMessage(`已新增 @${username}`, 'success');
          crawlUsernameInput.value = '';
          
          // Add to DOM
          if (crawlEmptyText) crawlEmptyText.remove();
          const item = document.createElement('div');
          item.className = 'crawl-account-item';
          item.setAttribute('data-username', username);
          item.innerHTML = `
            <div class="crawl-account-info">
              <span class="crawl-account-name">@${username}</span>
              <a href="https://x.com/${username}" target="_blank" rel="noopener noreferrer" class="crawl-account-link" title="前往 Twitter">↗</a>
            </div>
            <div class="crawl-account-settings" style="display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;">
              <label style="display: flex; align-items: center; gap: 0.25rem; font-size: 0.8rem; cursor: pointer; color: var(--text-secondary);">
                <input type="checkbox" class="toggle-enabled-cb" data-username="${username}" checked />
                <span>啟用自動爬取</span>
              </label>
              <label style="display: flex; align-items: center; gap: 0.25rem; font-size: 0.8rem; cursor: pointer; color: var(--text-secondary);">
                <input type="checkbox" class="toggle-crawlall-cb" data-username="${username}" />
                <span>爬取全部歷史圖片</span>
              </label>
              <button class="btn btn-danger remove-crawl-btn" data-username="${username}" style="font-size: 0.8rem; padding: 0.25rem 0.5rem; margin-left: 0.5rem;">移除</button>
            </div>
          `;
          crawlAccountsList?.appendChild(item);
          
          // Attach remove handler
          item.querySelector('.remove-crawl-btn')?.addEventListener('click', handleRemoveCrawl);
          // Attach settings change handlers
          item.querySelectorAll('input[type="checkbox"]').forEach(cb => {
            cb.addEventListener('change', handleToggleCrawlSetting);
          });
        } else {
          showCrawlMessage(data.error || '新增失敗', 'error');
        }
      } catch (err) {
        showCrawlMessage('網路錯誤，請稍後再試', 'error');
      } finally {
        addCrawlBtn.disabled = false;
        addCrawlBtn.textContent = '新增帳號';
      }
    });
  }

  async function handleToggleCrawlSetting(this: HTMLInputElement) {
    const username = this.getAttribute('data-username');
    if (!username) return;

    const isEnabledToggle = this.classList.contains('toggle-enabled-cb');
    const isCrawlAllToggle = this.classList.contains('toggle-crawlall-cb');

    const payload: any = { username };
    if (isEnabledToggle) {
      payload.enabled = this.checked;
    } else if (isCrawlAllToggle) {
      payload.crawl_all = this.checked;
    }

    this.disabled = true;

    try {
      const res = await fetch('/api/crawl-accounts', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      const data = await res.json();

      if (!res.ok || !data.success) {
        this.checked = !this.checked;
        alert(`更新設定失敗：${data.error || '未知錯誤'}`);
      }
    } catch (err) {
      this.checked = !this.checked;
      alert('更新設定失敗，網路或伺服器錯誤。');
    } finally {
      this.disabled = false;
    }
  }

  async function handleRemoveCrawl(this: HTMLElement) {
    const username = this.getAttribute('data-username');
    if (!username) return;
    if (!confirm(`確定要移除 @${username} 嗎？`)) return;

    (this as HTMLButtonElement).disabled = true;
    this.textContent = '移除中...';

    try {
      const res = await fetch('/api/crawl-accounts', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username })
      });
      const data = await res.json();

      if (res.ok && data.success) {
        const item = document.querySelector(`.crawl-account-item[data-username="${username}"]`);
        if (item) item.remove();

        const remaining = document.querySelectorAll('.crawl-account-item');
        if (remaining.length === 0 && crawlAccountsList) {
          const empty = document.createElement('p');
          empty.className = 'empty-text';
          empty.id = 'crawl-empty-text';
          empty.textContent = '尚未新增任何爬取帳號。';
          crawlAccountsList.appendChild(empty);
        }
        showCrawlMessage(`已移除 @${username}`, 'success');
      } else {
        showCrawlMessage(data.error || '移除失敗', 'error');
        (this as HTMLButtonElement).disabled = false;
        this.textContent = '移除';
      }
    } catch (err) {
      showCrawlMessage('網路錯誤', 'error');
      (this as HTMLButtonElement).disabled = false;
      this.textContent = '移除';
    }
  }

  // Attach remove handlers to existing buttons
  document.querySelectorAll('.remove-crawl-btn').forEach(btn => {
    btn.addEventListener('click', handleRemoveCrawl);
  });

  // =========== Admin List Filtering and Pagination ===========
  const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
  const authorFilter = document.getElementById('author-filter') as HTMLSelectElement | null;
  const tagFilter = document.getElementById('tag-filter') as HTMLSelectElement | null;
  const paginationInfo = document.getElementById('pagination-info');
  const prevPageBtn = document.getElementById('prev-page-btn') as HTMLButtonElement | null;
  const nextPageBtn = document.getElementById('next-page-btn') as HTMLButtonElement | null;
  const totalCountDisplay = document.getElementById('total-count-display');
  const imageRows = document.querySelectorAll('.image-row');

  const ITEMS_PER_PAGE = 10;
  let currentPage = 1;
  let filteredRows: HTMLElement[] = [];

  // Parse rows data
  const rowsData = Array.from(imageRows).map((row) => {
    const el = row as HTMLElement;
    const title = (el.querySelector('.image-title')?.textContent || '').toLowerCase();
    const author = (el.querySelector('.image-author')?.textContent || '').toLowerCase().replace(/^@/, '');
    const description = (el.querySelector('.image-desc-preview')?.textContent || '').toLowerCase();
    const tags: string[] = [];
    el.querySelectorAll('.table-tag').forEach(tagEl => {
      tags.push((tagEl.textContent || '').replace(/^#/, '').trim());
    });

    return { el, title, author, description, tags };
  });

  // Populate filter selectors
  if (authorFilter && tagFilter) {
    const uniqueAuthors = Array.from(new Set(rowsData.map(r => r.author).filter(Boolean))).sort();
    const uniqueTags = Array.from(new Set(rowsData.flatMap(r => r.tags).filter(Boolean))).sort();

    uniqueAuthors.forEach(author => {
      const opt = document.createElement('option');
      opt.value = author;
      opt.textContent = `@${author}`;
      authorFilter.appendChild(opt);
    });

    uniqueTags.forEach(tag => {
      const opt = document.createElement('option');
      opt.value = tag;
      opt.textContent = `#${tag}`;
      tagFilter.appendChild(opt);
    });
  }

  function applyFilters() {
    // Uncheck checkboxes when filters change to prevent deleting non-visible items
    document.querySelectorAll('.image-select-checkbox').forEach(cb => {
      (cb as HTMLInputElement).checked = false;
    });
    if (selectAllCheckbox) selectAllCheckbox.checked = false;
    updateBulkActionsState();

    const searchVal = (searchInput?.value || '').trim().toLowerCase();
    const authorVal = (authorFilter?.value || '').toLowerCase();
    const tagVal = (tagFilter?.value || '');

    filteredRows = [];

    rowsData.forEach(row => {
      // Check search
      const matchesSearch = !searchVal || 
        row.title.includes(searchVal) || 
        row.author.includes(searchVal) || 
        row.description.includes(searchVal);

      // Check author
      const matchesAuthor = !authorVal || row.author === authorVal;

      // Check tag
      const matchesTag = !tagVal || row.tags.includes(tagVal);

      if (matchesSearch && matchesAuthor && matchesTag) {
        filteredRows.push(row.el);
      } else {
        row.el.style.display = 'none';
      }
    });

    // Reset pagination to first page after filtering
    currentPage = 1;
    updatePagination();
  }

  function updatePagination() {
    const totalItems = filteredRows.length;
    const totalPages = Math.ceil(totalItems / ITEMS_PER_PAGE) || 1;

    // Bounds check
    if (currentPage < 1) currentPage = 1;
    if (currentPage > totalPages) currentPage = totalPages;

    const startIndex = (currentPage - 1) * ITEMS_PER_PAGE;
    const endIndex = Math.min(startIndex + ITEMS_PER_PAGE, totalItems);

    // Hide all first
    rowsData.forEach(row => {
      row.el.style.display = 'none';
    });

    // Show current page items
    for (let i = startIndex; i < endIndex; i++) {
      filteredRows[i].style.display = 'table-row';
    }

    // Update pagination controls
    if (paginationInfo) {
      if (totalItems > 0) {
        paginationInfo.textContent = `顯示第 ${startIndex + 1}-${endIndex} 筆，共 ${totalItems} 筆`;
      } else {
        paginationInfo.textContent = '查無任何貼文';
      }
    }

    if (totalCountDisplay) {
      totalCountDisplay.textContent = totalItems.toString();
    }

    if (prevPageBtn) prevPageBtn.disabled = currentPage === 1;
    if (nextPageBtn) nextPageBtn.disabled = currentPage === totalPages;
  }

  // Event Listeners
  searchInput?.addEventListener('input', applyFilters);
  authorFilter?.addEventListener('change', applyFilters);
  tagFilter?.addEventListener('change', applyFilters);

  prevPageBtn?.addEventListener('click', () => {
    if (currentPage > 1) {
      currentPage--;
      updatePagination();
    }
  });

  nextPageBtn?.addEventListener('click', () => {
    const totalPages = Math.ceil(filteredRows.length / ITEMS_PER_PAGE);
    if (currentPage < totalPages) {
      currentPage++;
      updatePagination();
    }
  });

  // Attach settings change handlers on page load
  document.querySelectorAll('.toggle-enabled-cb, .toggle-crawlall-cb').forEach(cb => {
    cb.addEventListener('change', handleToggleCrawlSetting);
  });

  // Listen for individual row checkbox changes
  document.addEventListener('change', (e) => {
    const target = e.target as HTMLElement;
    if (target && target.classList.contains('image-select-checkbox')) {
      updateBulkActionsState();
    }
  });

  // Select all checkbox handler
  selectAllCheckbox?.addEventListener('change', () => {
    const isChecked = selectAllCheckbox.checked;
    
    // Check/uncheck only currently filtered/visible rows
    filteredRows.forEach(rowEl => {
      const cb = rowEl.querySelector('.image-select-checkbox') as HTMLInputElement | null;
      if (cb) {
        cb.checked = isChecked;
      }
    });

    updateBulkActionsState();
  });

  // Bulk delete action handler
  bulkDeleteBtn?.addEventListener('click', async () => {
    const checkedCheckboxes = document.querySelectorAll('.image-select-checkbox:checked');
    const ids = Array.from(checkedCheckboxes).map(cb => parseInt(cb.getAttribute('data-id') || '', 10)).filter(id => !isNaN(id));

    if (ids.length === 0) return;

    const confirmed = confirm(`確定要刪除這 ${ids.length} 張照片嗎？\n這會自資料庫中移除，並同步刪除 R2 儲存的實體檔案，此操作無法復原！`);
    if (!confirmed) return;

    bulkDeleteBtn.disabled = true;
    bulkDeleteBtn.textContent = '刪除中...';

    try {
      const response = await fetch('/api/images/bulk-delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ids })
      });
      const data = await response.json();

      if (response.ok && data.success) {
        alert(`成功刪除 ${data.count} 筆照片！`);
        window.location.reload();
      } else {
        alert(data.error || '刪除失敗');
        bulkDeleteBtn.disabled = false;
        bulkDeleteBtn.textContent = '刪除所選';
      }
    } catch (err) {
      console.error('Error in bulk delete:', err);
      alert('發生網路錯誤，請重試');
      bulkDeleteBtn.disabled = false;
      bulkDeleteBtn.textContent = '刪除所選';
    }
  });

  // Initialize
  applyFilters();
</script>

<style>
  .admin-container {
    padding: 2.5rem 0;
  }

  .admin-header {
    margin-bottom: 2rem;
  }

  .admin-header h1 {
    font-size: 1.8rem;
    margin-bottom: 0.5rem;
  }

  .admin-header p {
    color: var(--text-secondary);
    font-size: 0.95rem;
  }

  .admin-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: start;
  }

  @media (min-width: 992px) {
    .admin-grid {
      grid-template-columns: 380px 1fr;
    }
  }

  .admin-panel {
    background-color: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: var(--shadow-sm);
  }

  .admin-panel h2 {
    font-size: 1.25rem;
    margin-bottom: 1.25rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 0.75rem;
  }

  /* Form Styling */
  .admin-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-group label {
    font-size: 0.85rem;
    font-weight: 500;
  }

  .required {
    color: var(--heart-color);
  }

  .form-group input[type="text"],
  .form-group input[type="url"],
  .form-group textarea {
    padding: 0.6rem 0.8rem;
    border-radius: 6px;
    border: 1px solid var(--border-color);
    background-color: var(--bg-secondary);
    color: var(--text-primary);
    font-family: inherit;
    font-size: 0.9rem;
    outline: none;
    transition: border-color var(--transition-speed) ease;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    border-color: var(--text-primary);
  }

  .form-help {
    font-size: 0.75rem;
    color: var(--text-secondary);
  }

  /* Reusable tags select checkbox */
  .existing-tags-wrapper {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.6rem;
    max-height: 120px;
    overflow-y: auto;
    border: 1px solid var(--border-color);
    padding: 0.6rem;
    border-radius: 6px;
    background-color: var(--bg-secondary);
  }

  .tag-checkbox-label {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.8rem;
    cursor: pointer;
  }

  .tag-checkbox-label input {
    cursor: pointer;
  }

  .empty-text {
    font-size: 0.8rem;
    color: var(--text-secondary);
  }

  /* File upload dropzone styles */
  .file-dropzone {
    position: relative;
    border: 1px dashed var(--border-color);
    border-radius: 6px;
    padding: 1.25rem;
    text-align: center;
    background-color: var(--bg-secondary);
    cursor: pointer;
    transition: border-color var(--transition-speed) ease;
  }

  .file-dropzone:hover {
    border-color: var(--text-primary);
  }

  .file-dropzone input[type="file"] {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: pointer;
  }

  .dropzone-text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }

  .upload-icon {
    font-size: 1.3rem;
  }

  .upload-prompt {
    font-size: 0.8rem;
    font-weight: 500;
  }

