---
interface Props {
  totalPosts: number;
  totalPhotos: number;
  totalVideos: number;
  pendingPosts: number;
  totalAccounts: number;
  enabledAccounts: number;
  authorStats: { author: string; author_display_name: string | null; photos: number; videos: number; photo_bytes: number; video_bytes: number }[];
}

const { totalPosts, totalPhotos, totalVideos, pendingPosts, totalAccounts, enabledAccounts, authorStats } = Astro.props;

// Helper to format bytes to human-readable size
function formatBytes(bytes: number): string {
  if (bytes === 0) return '0 B';
  const k = 1024;
  const sizes = ['B', 'KB', 'MB', 'GB', 'TB'];
  const i = Math.floor(Math.log(bytes) / Math.log(k));
  return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
}

// Calculate totals for summary row
const totalPhotosSum = authorStats.reduce((sum, item) => sum + item.photos, 0);
const totalVideosSum = authorStats.reduce((sum, item) => sum + item.videos, 0);
const totalPhotoBytesSum = authorStats.reduce((sum, item) => sum + item.photo_bytes, 0);
const totalVideoBytesSum = authorStats.reduce((sum, item) => sum + item.video_bytes, 0);
const totalMediaSum = totalPhotosSum + totalVideosSum;
const totalBytesSum = totalPhotoBytesSum + totalVideoBytesSum;
---

<section
  id="panel-overview"
  class="dashboard-panel"
  role="tabpanel"
  aria-labelledby="tab-overview"
  data-admin-panel="overview"
  hidden
>
  <div class="overview-grid">
    <article class="overview-card">
      <span>全部貼文</span>
      <strong>{totalPosts}</strong>
      <small>{totalPhotos} 張圖片 + {totalVideos} 部影片</small>
    </article>
    <article class="overview-card">
      <span>待審查</span>
      <strong>{pendingPosts}</strong>
    </article>
    <article class="overview-card">
      <span>爬蟲帳號</span>
      <strong>{totalAccounts}</strong>
      <small>{enabledAccounts} 個啟用</small>
    </article>
    <article class="overview-card storage-panel" id="storage-panel">
      <span>R2 容量</span>
      <strong id="storage-used">讀取中...</strong>
      <div class="storage-bar-wrap">
        <div class="storage-bar-fill" id="storage-bar-fill" style="width: 0%;"></div>
      </div>
      <button type="button" id="storage-reconcile-btn" class="btn">重新計算</button>
      <p class="storage-warning" id="storage-warning" hidden></p>
    </article>
  </div>

  <div class="author-stats-card" style="margin-top: 1.5rem; background-color: var(--bg-card); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.25rem;">
    <h3 style="margin-top: 0; margin-bottom: 0.75rem; font-size: 1.1rem; display: flex; align-items: center; gap: 0.4rem;">
      👤 博主貼文統計
    </h3>
    <div style="overflow-x: auto;">
      <table style="width: 100%; border-collapse: collapse; font-size: 0.85rem; text-align: left;">
        <thead>
          <tr style="border-bottom: 1px solid var(--border-color); color: var(--text-secondary);">
            <th style="padding: 0.5rem 0.75rem; cursor: pointer; user-select: none;" class="sort-header" data-sort="author">博主帳號 <span class="sort-icon">⇅</span></th>
            <th style="padding: 0.5rem 0.75rem; text-align: center; cursor: pointer; user-select: none;" class="sort-header" data-sort="photos">圖片數 <span class="sort-icon">⇅</span></th>
            <th style="padding: 0.5rem 0.75rem; text-align: center; cursor: pointer; user-select: none;" class="sort-header" data-sort="videos">影片數 <span class="sort-icon">⇅</span></th>
            <th style="padding: 0.5rem 0.75rem; text-align: right; cursor: pointer; user-select: none;" class="sort-header" data-sort="media">總計媒體數 <span class="sort-icon">⇅</span></th>
            <th style="padding: 0.5rem 0.75rem; text-align: right; cursor: pointer; user-select: none;" class="sort-header" data-sort="bytes">使用容量 <span class="sort-icon">⇅</span></th>
          </tr>
        </thead>
        <tbody id="author-stats-tbody">
          {authorStats.map((item, index) => (
            <tr 
              style="border-bottom: 1px dashed var(--border-color); transition: background-color 0.2s;" 
              class="stat-row"
              data-index={index}
              data-author={item.author_display_name || item.author}
              data-photos={item.photos}
              data-videos={item.videos}
              data-media={item.photos + item.videos}
              data-bytes={item.photo_bytes + item.video_bytes}
            >
              <td style="padding: 0.6rem 0.75rem;">
                <a href={`https://x.com/${item.author}`} target="_blank" rel="noopener noreferrer" style="color: var(--text-primary); text-decoration: none; font-weight: 500;">
                  {item.author_display_name ? `${item.author_display_name} (@${item.author})` : `@${item.author}`}
                </a>
              </td>
              <td style="padding: 0.6rem 0.75rem; text-align: center; color: var(--text-secondary);">
                {item.photos} 張 <span style="font-size: 0.75rem; color: var(--text-secondary); opacity: 0.85;">({formatBytes(item.photo_bytes)})</span>
              </td>
              <td style="padding: 0.6rem 0.75rem; text-align: center; color: var(--text-secondary);">
                {item.videos} 部 <span style="font-size: 0.75rem; color: var(--text-secondary); opacity: 0.85;">({formatBytes(item.video_bytes)})</span>
              </td>
              <td style="padding: 0.6rem 0.75rem; text-align: right; font-weight: 600; color: var(--text-primary);">
                {item.photos + item.videos}
              </td>
              <td style="padding: 0.6rem 0.75rem; text-align: right; color: var(--text-secondary); font-weight: 500;">
                {formatBytes(item.photo_bytes + item.video_bytes)}
              </td>
            </tr>
          ))}
          {authorStats.length > 0 && (
            <tr class="total-row" style="border-top: 2px solid var(--border-color); font-weight: 700; background-color: var(--bg-secondary);">
              <td style="padding: 0.6rem 0.75rem; color: var(--text-primary);">總計 (Total)</td>
              <td style="padding: 0.6rem 0.75rem; text-align: center; color: var(--text-primary);">
                {totalPhotosSum} 張 <span style="font-size: 0.75rem; font-weight: 500; color: var(--text-secondary);">({formatBytes(totalPhotoBytesSum)})</span>
              </td>
              <td style="padding: 0.6rem 0.75rem; text-align: center; color: var(--text-primary);">
                {totalVideosSum} 部 <span style="font-size: 0.75rem; font-weight: 500; color: var(--text-secondary);">({formatBytes(totalVideoBytesSum)})</span>
              </td>
              <td style="padding: 0.6rem 0.75rem; text-align: right; color: var(--text-primary);">{totalMediaSum}</td>
              <td style="padding: 0.6rem 0.75rem; text-align: right; color: var(--text-primary);">{formatBytes(totalBytesSum)}</td>
            </tr>
          )}
          {authorStats.length === 0 && (
            <tr>
              <td colspan="5" style="text-align: center; padding: 1.5rem; color: var(--text-secondary);">
                目前尚無任何博主統計資料。
              </td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
  </div>

  <div class="quick-actions" aria-label="快捷操作" style="margin-top: 1.5rem;">
    <a href="#upload" class="btn btn-primary">新增貼文</a>
    <a href="#posts" class="btn" data-post-status="pending">查看待審查</a>
    <a href="#crawler" class="btn">管理爬蟲帳號</a>
    <a href="#auto-tag" class="btn">執行 Auto-tag</a>
  </div>
</section>

<style>
  .stat-row:hover {
    background-color: var(--bg-secondary);
  }
  .sort-header {
    transition: background-color 0.2s, color 0.2s;
    border-radius: 4px;
  }
  .sort-header:hover {
    background-color: var(--bg-secondary);
    color: var(--text-primary) !important;
  }
  .sort-header.active {
    color: var(--text-primary) !important;
  }
  .sort-icon {
    display: inline-block;
    margin-left: 4px;
    font-size: 0.75rem;
    opacity: 0.6;
    transition: opacity 0.2s;
  }
  .sort-header.active .sort-icon {
    opacity: 1;
  }
</style>

<script>
  function initTableSorting() {
    const tbody = document.getElementById('author-stats-tbody');
    if (!tbody) return;

    const headers = document.querySelectorAll('.sort-header');
    const rows = Array.from(tbody.querySelectorAll('.stat-row'));
    const totalRow = tbody.querySelector('.total-row');

    let currentSortKey: string | null = null;
    let currentDir: 'desc' | 'asc' | 'default' = 'default';

    headers.forEach((header) => {
      header.addEventListener('click', () => {
        const sortKey = header.getAttribute('data-sort');
        if (!sortKey) return;

        // Cycle through: desc -> asc -> default
        if (currentSortKey === sortKey) {
          if (currentDir === 'desc') {
            currentDir = 'asc';
          } else if (currentDir === 'asc') {
            currentDir = 'default';
          } else {
            currentDir = 'desc';
          }
        } else {
          currentSortKey = sortKey;
          currentDir = 'desc';
        }

        // Sort the rows array
        rows.sort((a, b) => {
          if (currentDir === 'default') {
            const idxA = parseInt(a.getAttribute('data-index') || '0', 10);
            const idxB = parseInt(b.getAttribute('data-index') || '0', 10);
            return idxA - idxB;
          }

          const valA = a.getAttribute(`data-${sortKey}`) || '';
          const valB = b.getAttribute(`data-${sortKey}`) || '';

          if (sortKey === 'author') {
            return currentDir === 'asc'
              ? valA.localeCompare(valB, 'zh-Hant')
              : valB.localeCompare(valA, 'zh-Hant');
          } else {
            const numA = parseFloat(valA) || 0;
            const numB = parseFloat(valB) || 0;
            return currentDir === 'asc' ? numA - numB : numB - numA;
          }
        });

        // Re-append elements in sorted order
        rows.forEach((row) => tbody.appendChild(row));
        if (totalRow) {
          tbody.appendChild(totalRow);
        }

        // Update indicators
        headers.forEach((h) => {
          const icon = h.querySelector('.sort-icon');
          if (!icon) return;

          if (h === header && currentDir !== 'default') {
            h.classList.add('active');
            icon.textContent = currentDir === 'desc' ? '▼' : '▲';
          } else {
            h.classList.remove('active');
            icon.textContent = '⇅';
          }
        });
      });
    });
  }

  // Run on page load
  initTableSorting();
</script>
