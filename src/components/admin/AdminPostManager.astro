---
// No longer receives all images — pagination is server-side via /api/admin-posts.
// Only the published/pending counts are passed for the tab labels.
interface Props {
  publishedCount: number;
  pendingCount: number;
  authors: { handle: string; label: string }[];
  tags: string[];
}
const { publishedCount, pendingCount, authors, tags } = Astro.props;
---

<!-- Manage List Panel -->
      <section id="panel-posts" class="admin-panel list-panel dashboard-panel" role="tabpanel" aria-labelledby="tab-posts" data-admin-panel="posts" hidden>
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; flex-wrap: wrap; gap: 0.5rem;">
          <h2 style="margin: 0;">照片貼文列表 (<span id="total-count-display">0</span>)</h2>
          <div class="view-toggle-group" style="display: inline-flex; gap: 0.25rem; background-color: var(--accent-light); padding: 0.2rem; border-radius: 6px; border: 1px solid var(--border-color);">
            <button type="button" id="view-toggle-table" class="view-toggle-btn active">
              📋 列表
            </button>
            <button type="button" id="view-toggle-grid" class="view-toggle-btn">
              ⬜ 網格
            </button>
          </div>
        </div>

        <!-- Tabs for Published vs Pending -->
        <div class="admin-tabs" style="display: flex; gap: 0.5rem; margin-bottom: 1rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem;">
          <button type="button" id="tab-published" class="tab-btn active" style="padding: 0.5rem 1rem; border: none; background: none; color: var(--text-primary); border-bottom: 2px solid var(--text-primary); cursor: pointer; font-weight: 600; font-size: 0.9rem; transition: all 0.2s ease;">
            已發佈 ({publishedCount})
          </button>
          <button type="button" id="tab-pending" class="tab-btn" style="padding: 0.5rem 1rem; border: none; background: none; color: var(--text-secondary); border-bottom: 2px solid transparent; cursor: pointer; font-weight: 500; font-size: 0.9rem; transition: all 0.2s ease;">
            待審查 ({pendingCount})
          </button>
        </div>

        <!-- Search and Filter Bar -->
        <div class="list-filters" style="display: flex; gap: 0.5rem; margin-bottom: 1rem; flex-wrap: wrap;">
          <input type="text" id="search-input" placeholder="搜尋標題、作者或內文..." style="flex: 2; min-width: 180px; padding: 0.5rem 0.8rem; border-radius: 6px; border: 1px solid var(--border-color); background-color: var(--bg-secondary); color: var(--text-primary); font-size: 0.85rem; outline: none; transition: border-color var(--transition-speed) ease;" onfocus="this.style.borderColor='var(--text-primary)'" onblur="this.style.borderColor='var(--border-color)'" />
          <select id="author-filter" style="flex: 1; min-width: 120px; padding: 0.5rem 0.8rem; border-radius: 6px; border: 1px solid var(--border-color); background-color: var(--bg-secondary); color: var(--text-primary); font-size: 0.85rem; cursor: pointer; outline: none; transition: border-color var(--transition-speed) ease;" onfocus="this.style.borderColor='var(--text-primary)'" onblur="this.style.borderColor='var(--border-color)'">
            <option value="">所有作者</option>
            {authors.map((a) => (
              <option value={a.handle}>{a.label}</option>
            ))}
          </select>
          <select id="tag-filter" style="flex: 1; min-width: 120px; padding: 0.5rem 0.8rem; border-radius: 6px; border: 1px solid var(--border-color); background-color: var(--bg-secondary); color: var(--text-primary); font-size: 0.85rem; cursor: pointer; outline: none; transition: border-color var(--transition-speed) ease;" onfocus="this.style.borderColor='var(--text-primary)'" onblur="this.style.borderColor='var(--border-color)'">
            <option value="">所有標籤</option>
            {tags.map((tag) => (
              <option value={tag}>#{tag}</option>
            ))}
          </select>
          <select id="media-filter" style="flex: 1; min-width: 120px; padding: 0.5rem 0.8rem; border-radius: 6px; border: 1px solid var(--border-color); background-color: var(--bg-secondary); color: var(--text-primary); font-size: 0.85rem; cursor: pointer; outline: none; transition: border-color var(--transition-speed) ease;" onfocus="this.style.borderColor='var(--text-primary)'" onblur="this.style.borderColor='var(--border-color)'">
            <option value="">所有類型</option>
            <option value="photo">僅相片</option>
            <option value="video">僅影片</option>
          </select>
        </div>

        <!-- Bulk Actions Bar -->
        <div id="bulk-actions-bar" class="bulk-actions">
          <span id="selected-count-display">已選擇 0 筆照片</span>
          <button id="bulk-delete-btn" class="btn btn-danger" style="font-size: 0.8rem; padding: 0.3rem 0.75rem;">
            刪除所選
          </button>
        </div>
        <div id="bulk-delete-progress" class="operation-progress" hidden>
          <progress id="bulk-delete-progress-bar" value="0" max="1"></progress>
          <span id="bulk-delete-progress-text">準備刪除...</span>
        </div>

        <div class="table-wrapper view-mode-table">
          <table class="admin-table" id="admin-post-table">
            <thead>
              <tr>
                <th style="width: 40px; text-align: center;"><input type="checkbox" id="select-all-checkbox" style="cursor: pointer;" /></th>
                <th>預覽</th>
                <th>貼文資訊</th>
                <th>標籤</th>
                <th style="text-align: right;">操作</th>
              </tr>
            </thead>
            <tbody id="admin-table-body">
              <!-- Rows injected via AJAX -->
            </tbody>
          </table>
          <div id="admin-empty-state" class="empty-table-state" style="display: none;">
            <p>資料庫目前無照片，請前往新增貼文分頁上傳。</p>
          </div>
        </div>

        <div class="grid-wrapper view-mode-grid" style="display: none;">
          <div class="admin-grid-view" id="admin-grid-view">
            <!-- Grid cards injected via AJAX -->
          </div>
          <div id="admin-grid-empty-state" class="empty-table-state" style="display: none;">
            <p>資料庫目前無照片，請前往新增貼文分頁上傳。</p>
          </div>
        </div>

        <!-- Pagination Controls -->
        <div class="pagination-controls" id="pagination-controls" style="display: flex; justify-content: space-between; align-items: center; margin-top: 1rem; font-size: 0.85rem; color: var(--text-secondary); border-top: 1px solid var(--border-color); padding-top: 0.75rem;">
          <span class="pagination-info" id="pagination-info">載入中...</span>
          <div style="display: flex; gap: 0.4rem;">
            <button type="button" id="first-page-btn" class="btn" style="padding: 0.25rem 0.6rem; font-size: 0.8rem;">最前頁</button>
            <button type="button" id="prev-page-btn" class="btn" style="padding: 0.25rem 0.6rem; font-size: 0.8rem;">上一頁</button>
            <button type="button" id="next-page-btn" class="btn" style="padding: 0.25rem 0.6rem; font-size: 0.8rem;">下一頁</button>
            <button type="button" id="last-page-btn" class="btn" style="padding: 0.25rem 0.6rem; font-size: 0.8rem;">最後頁</button>
          </div>
        </div>
      </section>
