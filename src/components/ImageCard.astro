---
interface Props {
  image: {
    id: number;
    title: string;
    r2_keys: string; // Comma separated list of R2 keys
    author: string;
    author_display_name?: string;
    author_url: string;
    post_url: string;
    description: string;
    likes: number;
    tags: string[];
    created_at?: string;
    updated_at?: string;
  };
}

const { image } = Astro.props;

// Split the keys
const keys = image.r2_keys.split(',').map(k => k.trim()).filter(k => k.length > 0);
const firstKey = keys[0] || '';
const totalImages = keys.length;

const firstImageUrl = `/api/r2/${encodeURIComponent(firstKey)}`;

// Detect video keys (by extension) so the card can render a <video> preview
// with a play overlay instead of an <img>. Animated WebP (converted from
// animated_gif) stays an <img> since browsers play it natively.
const VIDEO_EXTS = new Set(['.mp4', '.webm', '.mov', '.m4v']);
const isVideoKey = (key: string) => VIDEO_EXTS.has((key.toLowerCase().match(/\.[a-z0-9]+$/)?.[0] ?? ''));
const firstIsVideo = isVideoKey(firstKey);

const hasPhoto = keys.some(k => !isVideoKey(k));
const hasVideo = keys.some(k => isVideoKey(k));

// Format date for display
function formatDate(dateStr?: string): string {
  if (!dateStr) return '';
  const d = new Date(dateStr);
  const year = d.getFullYear();
  const month = String(d.getMonth() + 1).padStart(2, '0');
  const day = String(d.getDate()).padStart(2, '0');
  return `${year}/${month}/${day}`;
}
const displayDate = image.updated_at 
  ? `✏️ ${formatDate(image.updated_at)}` 
  : (image.created_at ? `${formatDate(image.created_at)}` : '');
---

<div class="image-card" data-id={image.id} data-created-at={image.created_at} data-has-photo={hasPhoto ? "true" : "false"} data-has-video={hasVideo ? "true" : "false"}>
  <!-- Image gallery group wrapper with carousel slider -->
  <div class="card-media media-slider" data-total={totalImages}>
    {totalImages > 1 && (
      <>
        <button type="button" class="slider-btn prev-btn" aria-label="上一張">‹</button>
        <button type="button" class="slider-btn next-btn" aria-label="下一張">›</button>
        <div class="slider-dots">
          {keys.map((_, idx) => (
            <span class={`slider-dot ${idx === 0 ? 'active' : ''}`} data-index={idx}></span>
          ))}
        </div>
      </>
    )}
    
    <div class="slider-slides image-gallery-group">
      {keys.map((key, idx) => {
        const mediaUrl = `/api/r2/${encodeURIComponent(key)}`;
        const isVid = isVideoKey(key);
        return (
          <a 
            href={mediaUrl} 
            class={`gallery-link slider-slide ${idx === 0 ? 'active' : ''}`} 
            data-index={idx}
            data-video={isVid ? '1' : null} 
            title={image.title || 'Twitter media'}
            style={idx === 0 ? '' : 'display: none;'}
          >
            {isVid ? (
              <div class="video-container">
                <video
                  src={mediaUrl}
                  class="gallery-video"
                  preload="metadata"
                  muted
                  playsinline
                  aria-label={image.title || 'Twitter video'}
                />
                <span class="video-play-overlay">▶</span>
              </div>
            ) : (
              <img
                src={mediaUrl}
                alt={image.title || 'Twitter photo'}
                loading="lazy"
                class="gallery-image"
              />
            )}
          </a>
        );
      })}
    </div>
  </div>
  
  <div class="card-content">
    <div class="card-tags">
      {image.tags.map((tag) => (
        <a href={`/search?tag=${encodeURIComponent(tag)}`} class="card-tag">#{tag}</a>
      ))}
    </div>

    {image.description && (
      <p class="card-desc" title={image.description}>
        {image.description}
      </p>
    )}
    
    <div class="card-footer">
      <div class="author-info">
        <span class="by-label">By</span>
        {image.author_url ? (
          <a href={image.author_url} target="_blank" rel="noopener noreferrer" class="author-link">
            {image.author_display_name ? `${image.author_display_name}@${image.author}` : `@${image.author}`}
          </a>
        ) : (
          <span class="author-text">{image.author_display_name ? `${image.author_display_name}@${image.author}` : `@${image.author}`}</span>
        )}
        {displayDate && <span class="card-date">{displayDate}</span>}
      </div>

      <div class="footer-actions" style="display: flex; align-items: center; gap: 0.5rem;">
        {image.post_url && (
          <a href={image.post_url} target="_blank" rel="noopener noreferrer" class="post-link-btn" title="查看原始推文">
            <span>🔗</span>
            <span>推文</span>
          </a>
        )}
        
        <button class="like-button" aria-label="Like this photo">
          <svg class="heart-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"></path>
          </svg>
          <span class="like-count">{image.likes}</span>
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  .image-card {
    background-color: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    min-width: 0;
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-speed) cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow var(--transition-speed) ease,
                border-color var(--transition-speed) ease;
  }

  .image-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--text-primary);
  }

  .card-media {
    position: relative;
    width: 100%;
    overflow: hidden;
    background-color: var(--bg-secondary);
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .gallery-link {
    width: 100%;
    display: block;
  }

  .gallery-image {
    width: 100%;
    height: auto;
    max-height: 320px;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .image-card:hover .gallery-image {
    transform: scale(1.02);
  }

  .gallery-video {
    width: 100%;
    height: auto;
    max-height: 320px;
    object-fit: cover;
    display: block;
    background-color: #000;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .image-card:hover .gallery-video {
    transform: scale(1.02);
  }

  .video-play-overlay {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 2.4rem;
    color: #fff;
    background: rgba(0, 0, 0, 0.45);
    border-radius: 50%;
    width: 3.2rem;
    height: 3.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.6);
  }

  .card-content {
    padding: 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border-top: 1px solid var(--border-color);
    flex-grow: 1;
    justify-content: space-between;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .card-tag {
    font-size: 0.85rem;
    color: var(--text-secondary);
    transition: color var(--transition-speed) ease;
  }

  .card-tag:hover {
    color: var(--text-primary);
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 0.2rem;
  }

  .author-info {
    font-size: 0.9rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.2rem;
  }

  .by-label {
    color: var(--text-secondary);
    flex-shrink: 0;
  }

  .author-link {
    font-weight: 500;
    color: var(--text-primary);
    border-bottom: 1px solid transparent;
    overflow-wrap: anywhere;
  }

  .author-link:hover {
    border-color: var(--text-primary);
  }

  .author-text {
    font-weight: 500;
    color: var(--text-primary);
    overflow-wrap: anywhere;
  }

  .like-button {
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-secondary);
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    white-space: nowrap;
    flex-shrink: 0;
    transition: all var(--transition-speed) ease;
  }

  .like-button:hover {
    color: var(--heart-color);
    background-color: var(--accent-light);
  }

  .like-button.liked {
    color: var(--heart-color);
  }

  .like-button.liked .heart-icon {
    fill: var(--heart-color);
    stroke: var(--heart-color);
    animation: heart-pop 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .heart-icon {
    width: 0.95rem;
    height: 0.95rem;
    transition: fill var(--transition-speed) ease, stroke var(--transition-speed) ease;
  }

  @keyframes heart-pop {
    0% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.4);
    }
    100% {
      transform: scale(1);
    }
  }

  .card-date {
    font-size: 0.75rem;
    color: var(--text-secondary);
    opacity: 0.7;
    margin-left: 0.3rem;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* Responsive fixes for card footer on narrow screens / tablet & mobile */
  @media (max-width: 800px) {
    .card-footer {
      flex-direction: column;
      align-items: stretch;
      gap: 0.5rem;
      margin-top: 0.4rem;
    }

    .author-info {
      width: 100%;
    }

    .footer-actions {
      width: 100%;
      justify-content: space-between;
    }
  }

  /* Media slider styles */
  .media-slider {
    position: relative;
    width: 100%;
  }

  .slider-slides {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .slider-slide {
    width: 100%;
    display: block;
  }

  .slider-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
    color: #fff;
    border: none;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    cursor: pointer;
    z-index: 5;
    opacity: 0;
    transition: opacity var(--transition-speed) ease, background-color var(--transition-speed) ease;
    user-select: none;
  }

  /* Show navigation buttons on hover */
  .media-slider:hover .slider-btn {
    opacity: 1;
  }

  .slider-btn:hover {
    background: rgba(0, 0, 0, 0.7);
  }

  .prev-btn {
    left: 10px;
    padding-right: 2px;
  }

  .next-btn {
    right: 10px;
    padding-left: 2px;
  }

  .slider-dots {
    position: absolute;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 6px;
    z-index: 5;
    background: rgba(0, 0, 0, 0.25);
    padding: 4px 8px;
    border-radius: 9999px;
    backdrop-filter: blur(4px);
  }

  .slider-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.5);
    cursor: pointer;
    transition: all var(--transition-speed) ease;
  }

  .slider-dot.active {
    background: #fff;
    transform: scale(1.2);
  }

  .video-container {
    position: relative;
    width: 100%;
    display: block;
  }
</style>
