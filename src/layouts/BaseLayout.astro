---
import Header from '../components/Header.astro';
import '../styles/global.css';
import 'photoswipe/style.css';
import '@fontsource/lxgw-wenkai-tc';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "極簡 Twitter 照片牆", 
  description = "展示精選 Twitter 博主的相簿，極簡設計，支援標籤分類與喜愛功能。" 
} = Astro.props;

const versionString = import.meta.env.PUBLIC_BUILD_VERSION || 'vUnknown';
---

<!DOCTYPE html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Meta tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Non-blocking theme setup script to avoid flashes -->
    <script is:inline>
      (function() {
        const storedTheme = localStorage.getItem('theme');
        if (storedTheme) {
          document.documentElement.setAttribute('data-theme', storedTheme);
        } else {
          const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          document.documentElement.setAttribute('data-theme', systemTheme);
          localStorage.setItem('theme', systemTheme);
        }
      })();
    </script>
  </head>
  <body>
    <Header version={versionString} />
    <main class="container">
      <slot />
    </main>
    <footer class="footer">
      <div class="container">
        <p>
          © 2026 Twitter Gallery. Built with Astro & Cloudflare Pages.
        </p>
      </div>
    </footer>

    <!-- Video lightbox modal (separate from PhotoSwipe, which is image-only) -->
    <div id="video-lightbox" class="video-lightbox" hidden>
      <button class="video-lightbox-close" aria-label="關閉">✕</button>
      <video id="video-lightbox-player" class="video-lightbox-player" controls autoplay playsinline></video>
    </div>

    <!-- PhotoSwipe 5 script bundled locally by Vite -->
    <script>
      import PhotoSwipeLightbox from 'photoswipe/lightbox';
      import PhotoSwipe from 'photoswipe';

      function initPhotoSwipe() {
        // Preload image dimensions for image (non-video) gallery links only.
        document.querySelectorAll('a.gallery-link:not([data-video="1"])').forEach((link) => {
          const href = link.getAttribute('href');
          if (!href || link.getAttribute('data-pswp-width')) return;

          const img = new Image();
          img.onload = () => {
            link.setAttribute('data-pswp-width', String(img.naturalWidth));
            link.setAttribute('data-pswp-height', String(img.naturalHeight));
          };
          img.src = href;
        });

        // Initialize PhotoSwipe Lightbox (image links only; video links are
        // handled by the custom video lightbox below).
        const lightbox = new PhotoSwipeLightbox({
          gallery: '.image-gallery-group',
          children: 'a.gallery-link:not([data-video="1"])',
          pswpModule: PhotoSwipe,
          // Fallback dimensions if images haven't preloaded yet
          errorMsg: 'The image cannot be loaded',
        });

        // If dimensions aren't preloaded yet, load them on the fly
        lightbox.addFilter('itemData', (itemData: any) => {
          if (!itemData.w || !itemData.h) {
            // Use sensible defaults; PhotoSwipe will resize once real dims load
            itemData.w = itemData.w || 1600;
            itemData.h = itemData.h || 1200;

            // Async-load real dimensions and update the slide
            const img = new Image();
            img.onload = () => {
              itemData.w = img.naturalWidth;
              itemData.h = img.naturalHeight;
              lightbox.pswp?.refreshSlideContent(itemData.index);
            };
            img.src = itemData.src;
          }
          return itemData;
        });

        lightbox.init();
      }

      // ---- Custom video lightbox (PhotoSwipe is image-only) ----
      function initVideoLightbox() {
        const lb = document.getElementById('video-lightbox');
        const player = document.getElementById('video-lightbox-player') as HTMLVideoElement | null;
        const closeBtn = document.querySelector('.video-lightbox-close');
        if (!lb || !player) return;

        function close() {
          player.pause();
          player.removeAttribute('src');
          player.load();
          lb.hidden = true;
        }
        function open(src: string) {
          player.src = src;
          lb.hidden = false;
          player.play().catch(() => { /* autoplay may be blocked; controls still work */ });
        }

        closeBtn?.addEventListener('click', close);
        lb.addEventListener('click', (e) => { if (e.target === lb) close(); });
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !lb.hidden) close(); });

        document.querySelectorAll('a.gallery-link[data-video="1"]').forEach((link) => {
          link.addEventListener('click', (e) => {
            e.preventDefault();
            const href = link.getAttribute('href');
            if (href) open(href);
          });
        });
      }

      // Run on initial load
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => { initPhotoSwipe(); initVideoLightbox(); });
      } else {
        initPhotoSwipe();
        initVideoLightbox();
      }
      // Support Astro page transitions
      document.addEventListener('astro:after-swap', () => { initPhotoSwipe(); initVideoLightbox(); });
    </script>
  </body>
</html>

<style>
  body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }
  main {
    flex: 1;
    width: 100%;
    min-width: 0;
    padding-bottom: 3rem;
  }
  .footer {
    padding: 2rem 0;
    border-top: 1px solid var(--border-color);
    text-align: center;
    font-size: 0.85rem;
    color: var(--text-secondary);
    background-color: var(--bg-secondary);
  }
  .video-lightbox {
    position: fixed;
    inset: 0;
    z-index: 2000;
    background: rgba(0, 0, 0, 0.92);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
  .video-lightbox[hidden] { display: none; }
  .video-lightbox-player {
    max-width: 90vw;
    max-height: 85vh;
    border-radius: 8px;
    background: #000;
  }
  .video-lightbox-close {
    position: absolute;
    top: 1rem;
    right: 1.2rem;
    background: rgba(255, 255, 255, 0.12);
    border: none;
    color: #fff;
    font-size: 1.4rem;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .video-lightbox-close:hover { background: rgba(255, 255, 255, 0.22); }
</style>
