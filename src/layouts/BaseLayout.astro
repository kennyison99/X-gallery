---
import Header from '../components/Header.astro';
import '../styles/global.css';
import 'photoswipe/style.css';
import '@fontsource/lxgw-wenkai-tc';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "極簡 Twitter 照片牆", 
  description = "展示精選 Twitter 博主的相簿，極簡設計，支援標籤分類與喜愛功能。" 
} = Astro.props;

const versionString = import.meta.env.PUBLIC_BUILD_VERSION || 'vUnknown';
---

<!DOCTYPE html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Meta tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Non-blocking theme setup script to avoid flashes -->
    <script is:inline>
      (function() {
        const storedTheme = localStorage.getItem('theme');
        if (storedTheme) {
          document.documentElement.setAttribute('data-theme', storedTheme);
        } else {
          const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          document.documentElement.setAttribute('data-theme', systemTheme);
          localStorage.setItem('theme', systemTheme);
        }
      })();
    </script>
  </head>
  <body>
    <Header version={versionString} />
    <main class="container">
      <slot />
    </main>
    <footer class="footer">
      <div class="container">
        <p>
          © 2026 Twitter Gallery. Built with Astro & Cloudflare Pages.
        </p>
      </div>
    </footer>

    <!-- PhotoSwipe 5 script bundled locally by Vite -->
    <script>
      import PhotoSwipeLightbox from 'photoswipe/lightbox';
      import PhotoSwipe from 'photoswipe';
      import { preparePhotoSwipeItem, wrapSlideIndex } from '../lib/gallery';

      function loadImageDimensions(link: HTMLAnchorElement): Promise<void> {
        return new Promise((resolve, reject) => {
          const preloader = new Image();

          preloader.onload = () => {
            const { naturalWidth: width, naturalHeight: height } = preloader;
            if (!width || !height) {
              reject(new Error('Image has no natural dimensions'));
              return;
            }

            link.dataset.pswpWidth = String(width);
            link.dataset.pswpHeight = String(height);
            resolve();
          };
          preloader.onerror = () => reject(new Error('Unable to load gallery image'));
          preloader.src = link.href;
        });
      }

      function guardGalleryClick(event: MouseEvent) {
        if (event.button !== 0 || event.ctrlKey || event.metaKey || event.shiftKey || event.altKey) {
          return;
        }

        const target = event.target;
        if (!(target instanceof Element)) return;

        const link = target.closest<HTMLAnchorElement>('a.gallery-link');
        if (!link) return;

        // PhotoSwipe deliberately allows native navigation while an instance is
        // opening or closing. Ordinary gallery clicks should never leave the app.
        event.preventDefault();

        if (link.dataset.video === '1' || link.dataset.pswpWidth || link.dataset.pswpDimensionError === '1') {
          return;
        }

        const image = link.querySelector<HTMLImageElement>('img');
        if (image?.naturalWidth && image.naturalHeight) return;

        event.stopImmediatePropagation();
        if (link.dataset.pswpLoading === '1') return;
        link.dataset.pswpLoading = '1';

        void loadImageDimensions(link)
          .catch(() => {
            // Let PhotoSwipe render its normal load error instead of navigating.
            link.dataset.pswpDimensionError = '1';
          })
          .finally(() => {
            delete link.dataset.pswpLoading;
            link.click();
          });
      }

      function initGalleryClickGuard() {
        if (document.documentElement.dataset.galleryClickGuard === '1') return;
        document.documentElement.dataset.galleryClickGuard = '1';
        document.addEventListener('click', guardGalleryClick, true);
      }

      function initPhotoSwipe() {
        // Initialize PhotoSwipe Lightbox
        const lightbox = new PhotoSwipeLightbox({
          gallery: '.image-gallery-group',
          children: 'a.gallery-link', // Include all links, even videos!
          pswpModule: PhotoSwipe,
          showHideAnimationType: 'fade',
          errorMsg: '無法載入內容',
        });

        // Add filter to handle video slides
        lightbox.addFilter('itemData', (itemData: any) => {
          return preparePhotoSwipeItem(itemData, {
            width: window.innerWidth,
            height: window.innerHeight,
          });
        });

        // Pause other videos when changing slides
        lightbox.on('afterChange', () => {
          const pswp = lightbox.pswp;
          if (!pswp) return;
          
          const container = pswp.container;
          if (!container) return;

          container.querySelectorAll('video').forEach((video) => {
            if (pswp.currSlide && pswp.currSlide.container && pswp.currSlide.container.contains(video)) {
              // Active slide video
              video.play().catch(() => {});
            } else {
              // Slide away - pause
              video.pause();
            }
          });
        });

        // Pause all videos when closed
        lightbox.on('close', () => {
          document.querySelectorAll('.pswp video').forEach((video: any) => {
            video.pause();
          });
        });

        lightbox.init();
      }

      function initSliders() {
        document.querySelectorAll('.media-slider').forEach((slider) => {
          if (slider.getAttribute('data-slider-initialized')) return;
          slider.setAttribute('data-slider-initialized', 'true');

          const slides = slider.querySelectorAll('.slider-slide') as NodeListOf<HTMLElement>;
          const dots = slider.querySelectorAll('.slider-dot');
          const prevBtn = slider.querySelector('.prev-btn');
          const nextBtn = slider.querySelector('.next-btn');
          if (slides.length <= 1) return;

          let currentIndex = 0;

          function showSlide(index: number) {
            currentIndex = wrapSlideIndex(index, slides.length);

            slides.forEach((slide, idx) => {
              if (idx === currentIndex) {
                slide.classList.add('active');
              } else {
                slide.classList.remove('active');
              }
            });

            dots.forEach((dot, idx) => {
              if (idx === currentIndex) {
                dot.classList.add('active');
              } else {
                dot.classList.remove('active');
              }
            });
          }

          prevBtn?.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            showSlide(currentIndex - 1);
          });

          nextBtn?.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            showSlide(currentIndex + 1);
          });

          dots.forEach((dot, idx) => {
            dot.addEventListener('click', (e) => {
              e.preventDefault();
              e.stopPropagation();
              showSlide(idx);
            });
          });
        });
      }

      initGalleryClickGuard();

      // Run on initial load
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => { initPhotoSwipe(); initSliders(); });
      } else {
        initPhotoSwipe();
        initSliders();
      }
      // Support Astro page transitions
      document.addEventListener('astro:after-swap', () => { initPhotoSwipe(); initSliders(); });
    </script>
  </body>
</html>

<style>
  body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }
  main {
    flex: 1;
    width: 100%;
    min-width: 0;
    padding-bottom: 3rem;
  }
  .footer {
    padding: 2rem 0;
    border-top: 1px solid var(--border-color);
    text-align: center;
    font-size: 0.85rem;
    color: var(--text-secondary);
    background-color: var(--bg-secondary);
  }

  /* PhotoSwipe video container styles */
  :global(.pswp__video-wrapper) {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  :global(.pswp__video-wrapper video) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    outline: none;
  }
</style>
